# ============================================
# Abraham of London - Environment Variables
# ============================================
# Copy to .env.local and fill in real values.
# For local recovery, you can also start from .env.local.example.
# NEVER commit .env or .env.local to git.
# ============================================

# ========================
# Application
# ========================
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME="Abraham of London"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.abrahamoflondon.org
SITE_URL=https://www.abrahamoflondon.org
SITE_DOMAIN=www.abrahamoflondon.org
ALLOWED_ORIGINS=http://localhost:3000,https://www.abrahamoflondon.org

# GitHub OAuth
# Supported aliases in code: GITHUB_ID / GITHUB_CLIENT_ID / AUTH_GITHUB_ID
# Supported secret aliases in code: GITHUB_SECRET / GITHUB_CLIENT_SECRET / AUTH_GITHUB_SECRET

GITHUB_CLIENT_ID=placeholder-github-client-id
GITHUB_CLIENT_SECRET=CHANGE_ME

# ========================
# Database
# ========================
DATABASE_URL="file:./prisma/dev.db"
DIRECT_URL="file:./prisma/dev.db"

# ========================
# Redis (optional)
# ========================
REDIS_URL=redis://127.0.0.1:6379
REDIS_DISABLED=true
USE_REDIS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========================
# Authentication
# ========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=30d
ENCRYPTION_KEY=CHANGE_ME
CSRF_SECRET=CHANGE_ME
ACCESS_COOKIE_SECRET=CHANGE_ME
SECURE_CLIENT_STATE_SECRET=CHANGE_ME
SESSION_COOKIE_PREFIX=aol

# ========================
# Admin
# ========================
ADMIN_JWT_SECRET=CHANGE_ME
ADMIN_API_KEY=CHANGE_ME
ADMIN_SECRET_TOKEN=CHANGE_ME
ADMIN_SECRET=CHANGE_ME
ADMIN_USER_EMAIL=admin@yourdomain.com
ADMIN_ALLOWED_EMAILS=admin@yourdomain.com
ADMIN_PASSWORD_HASH=CHANGE_ME

# ========================
# Cron / Internal
# ========================
CRON_SECRET=CHANGE_ME
INTERNAL_BYPASS_KEY=CHANGE_ME
AUDIT_EDGE_SECRET=CHANGE_ME
ACTION_TOKEN_SECRET=CHANGE_ME

# ========================
# Brand / Identity
# ========================
AOL_BRAND_NAME="Abraham of London"
AOL_ISSUER_ID=AOL-LOCAL
AOL_HASH_SALT=CHANGE_ME
AOL_WATERMARK_ISSUER_MEMBERID=SYSTEM_ARCHIVE
AOL_SESSION_TTL_DAYS=30
AOL_TOKENSTORE_BACKEND=postgres
AOL_TOKEN_TTL_HOURS=72
DYNAMIC_THRESHOLD_SALT=CHANGE_ME
# Required for vault / brief PDF watermarking. Must be a real secret with length >= 16.
SYSTEM_INTEGRITY_SALT=CHANGE_ME
ANONYMITY_SALT=CHANGE_ME
DENYLIST_PEPPER=CHANGE_ME

# ========================
# Email
# ========================
EMAIL_PROVIDER=resend
EMAIL_FROM=info@yourdomain.com
EMAIL_REPLY_TO=info@yourdomain.com
# Required for invite / nudge email delivery. Leave unset only if local email sending should be skipped.
RESEND_API_KEY=CHANGE_ME
RESEND_WEBHOOK_SECRET=CHANGE_ME
MAIL_FROM="Your Name <info@yourdomain.com>"
MAIL_TO=info@yourdomain.com
CONTACT_RECEIVER_EMAIL=info@yourdomain.com
NOTIFICATION_WEBHOOK_URL=

# ========================
# Inner Circle
# ========================
INNER_CIRCLE_STORE=postgres
INNER_CIRCLE_DB_URL=CHANGE_ME
INNER_CIRCLE_JWT_SECRET=CHANGE_ME
INNER_CIRCLE_KEY_SECRET=CHANGE_ME

# ========================
# Enterprise / Diagnostics
# ========================
ENTERPRISE_ALIGNMENT_INVITE_SECRET=CHANGE_ME
DIAGNOSTIC_HMAC_SECRET=CHANGE_ME
DIAGNOSTIC_WATERMARK_SECRET=CHANGE_ME
DIAGNOSTIC_STORAGE_PROVIDER=local
DIAGNOSTIC_DEFAULT_CURRENCY=gbp

# ========================
# Sovereign / OGR
# ========================
OGR_SESSION_SECRET=CHANGE_ME
OGR_SOVEREIGN_KEY=CHANGE_ME
SOVEREIGN_ACCESS_KEY=CHANGE_ME

# ========================
# Payments (Stripe)
# ========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ========================
# AI
# ========================
OPENAI_API_KEY=

# ========================
# OAuth Integrations (Behavioral Data)
# ========================
# Google OAuth 2.0 — for Calendar sync (Pattern-Breaker Contract verification)
# Get these from https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Slack OAuth 2.0 — for workspace responsiveness signals
# Get these from https://api.slack.com/apps -> Your App -> OAuth & Permissions
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# OAuth token encryption key — used to encrypt tokens at rest via AES-256-GCM
# Must be at least 32 characters. No secret fallback is permitted.
OAUTH_TOKEN_ENCRYPTION_KEY=CHANGE_ME

# LinkedIn governed outbound publishing
# Text-only member-profile publishing v1. Do not add real secrets to source.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_TOKEN_ENCRYPTION_KEY=
LINKEDIN_OAUTH_SCOPES=openid profile w_member_social w_organization_social r_organization_social
LINKEDIN_DEFAULT_OWNER_TYPE=organization
LINKEDIN_ORGANIZATION_URN=
LINKEDIN_PUBLISHING_ENABLED=true

# ========================
# PDF
# ========================
PDF_OUTPUT_DIR=./public/pdfs
PDF_TEMP_DIR=./.temp/pdfs
PDF_FONTS_DIR=./public/fonts
ARTIFACT_ACCESS_SECRET=CHANGE_ME
DOWNLOAD_TOKEN_SECRET=CHANGE_ME

# ========================
# Security
# ========================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ========================
# Feature Flags
# ========================
ENABLE_ANALYTICS=false
ENABLE_PDF_GENERATION=true
ENABLE_EMAIL_NOTIFICATIONS=false
REDIS_DISABLED=true
SKIP_DB=false
LOG_LEVEL=warn
VAULT_CACHE_SECONDS=300

# ========================
# Development Only
# ========================
DEBUG_CONTENTLAYER=false
IS_WINDOWS=false
PREMIUM_ASSET_BACKEND=local

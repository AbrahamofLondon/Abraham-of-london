# ============================================
# Abraham of London - Environment Variables
# ============================================
# Copy to .env.local and fill in real values.
# NEVER commit .env or .env.local to git.
# ============================================

# ========================
# Application
# ========================
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME="Abraham of London"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.abrahamoflondon.org
SITE_URL=https://www.abrahamoflondon.org
SITE_DOMAIN=www.abrahamoflondon.org
ALLOWED_ORIGINS=http://localhost:3000,https://www.abrahamoflondon.org

# ========================
# Database
# ========================
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ========================
# Redis (optional)
# ========================
REDIS_URL=redis://127.0.0.1:6379
REDIS_DISABLED=true
USE_REDIS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========================
# Authentication
# ========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=30d
ENCRYPTION_KEY=CHANGE_ME
CSRF_SECRET=CHANGE_ME
ACCESS_COOKIE_SECRET=CHANGE_ME
SESSION_COOKIE_PREFIX=aol

# ========================
# Admin
# ========================
ADMIN_JWT_SECRET=CHANGE_ME
ADMIN_API_KEY=CHANGE_ME
ADMIN_SECRET_TOKEN=CHANGE_ME
ADMIN_SECRET=CHANGE_ME
ADMIN_USER_EMAIL=admin@yourdomain.com
ADMIN_USER_PASSWORD=CHANGE_ME
ADMIN_ALLOWED_EMAILS=admin@yourdomain.com
ADMIN_PASSWORD_HASH=CHANGE_ME

# ========================
# Cron / Internal
# ========================
CRON_SECRET=CHANGE_ME
INTERNAL_BYPASS_KEY=CHANGE_ME
AUDIT_EDGE_SECRET=CHANGE_ME

# ========================
# Brand / Identity
# ========================
AOL_BRAND_NAME="Abraham of London"
AOL_ISSUER_ID=AOL-LOCAL
AOL_HASH_SALT=CHANGE_ME
AOL_WATERMARK_ISSUER_MEMBERID=SYSTEM_ARCHIVE
AOL_SESSION_TTL_DAYS=30
AOL_TOKENSTORE_BACKEND=postgres
AOL_TOKEN_TTL_HOURS=72
SYSTEM_INTEGRITY_SALT=CHANGE_ME
ANONYMITY_SALT=CHANGE_ME
DENYLIST_PEPPER=CHANGE_ME

# ========================
# Email
# ========================
EMAIL_PROVIDER=resend
EMAIL_FROM=info@yourdomain.com
EMAIL_REPLY_TO=info@yourdomain.com
RESEND_API_KEY=CHANGE_ME
MAIL_FROM="Your Name <info@yourdomain.com>"
MAIL_TO=info@yourdomain.com
CONTACT_RECEIVER_EMAIL=info@yourdomain.com
NOTIFICATION_WEBHOOK_URL=

# ========================
# Inner Circle
# ========================
INNER_CIRCLE_STORE=postgres
INNER_CIRCLE_DB_URL=CHANGE_ME
INNER_CIRCLE_JWT_SECRET=CHANGE_ME
INNER_CIRCLE_KEY_SECRET=CHANGE_ME

# ========================
# Enterprise / Diagnostics
# ========================
ENTERPRISE_ALIGNMENT_INVITE_SECRET=CHANGE_ME
DIAGNOSTIC_HMAC_SECRET=CHANGE_ME
DIAGNOSTIC_WATERMARK_SECRET=CHANGE_ME
DIAGNOSTIC_STORAGE_PROVIDER=local
DIAGNOSTIC_DEFAULT_CURRENCY=gbp

# ========================
# Sovereign / OGR
# ========================
OGR_SESSION_SECRET=CHANGE_ME
OGR_SOVEREIGN_KEY=CHANGE_ME
SOVEREIGN_ACCESS_KEY=CHANGE_ME

# ========================
# Payments (Stripe)
# ========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ========================
# AI
# ========================
OPENAI_API_KEY=

# ========================
# PDF
# ========================
PDF_OUTPUT_DIR=./public/pdfs
PDF_TEMP_DIR=./.temp/pdfs
PDF_FONTS_DIR=./public/fonts
ARTIFACT_ACCESS_SECRET=CHANGE_ME
DOWNLOAD_TOKEN_SECRET=CHANGE_ME

# ========================
# Security
# ========================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ========================
# Feature Flags
# ========================
ENABLE_ANALYTICS=false
ENABLE_PDF_GENERATION=true
ENABLE_EMAIL_NOTIFICATIONS=false
REDIS_DISABLED=true
SKIP_DB=false
LOG_LEVEL=warn
VAULT_CACHE_SECONDS=300

# ========================
# Development Only
# ========================
DEBUG_CONTENTLAYER=false
IS_WINDOWS=false
PREMIUM_ASSET_BACKEND=local

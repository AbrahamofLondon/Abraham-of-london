# Local-only environment template for recovery work.
# Copy to .env.local and fill in real values. Do not commit .env.local.
# Do not set NODE_ENV — Next.js controls it; a hard-coded value breaks builds.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

DATABASE_URL="postgresql://aol:aol_local@127.0.0.1:55433/aol_dev?schema=public"
DIRECT_URL="postgresql://aol:aol_local@127.0.0.1:55433/aol_dev?schema=public"

# Local build toggles
REDIS_DISABLED=true
USE_REDIS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required for PDF / brief watermark generation.
# Must be a real secret with length >= 16.
SYSTEM_INTEGRITY_SALT=
AOL_HASH_SALT=

# Required only when local flows must send email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Abraham of London <info@yourdomain.com>
MAIL_FROM=Abraham of London <info@yourdomain.com>
EMAIL_FROM=info@yourdomain.com
EMAIL_REPLY_TO=info@yourdomain.com

# Common local runtime secrets
ADMIN_EMAIL=
NEXTAUTH_SECRET=
JWT_SECRET=
CRON_SECRET=
ARTIFACT_ACCESS_SECRET=
DOWNLOAD_TOKEN_SECRET=
DIAGNOSTIC_WATERMARK_SECRET=

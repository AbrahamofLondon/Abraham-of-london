/**
 * Legacy compatibility wrapper.
 *
 * Authority now lives in:
 * - NextAuth for identity
 * - `getUserAccess(prisma, userId)` for access resolution
 *
 * Keep this file only so older imports fail closed onto the canonical resolver.
 */

import { prisma } from "@/lib/prisma.server";
import { getUserAccess as resolveUserAccess } from "./get-user-access";

export async function getUserAccess(userId: string) {
  return resolveUserAccess(prisma, userId);
}

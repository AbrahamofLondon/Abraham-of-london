    "lint": "next lint",
    "audit:access": "tsx scripts/audit-access-consistency.ts",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:safe": "tsc --noEmit --skipLibCheck 2>&1 || echo 'TypeScript errors found (non-blocking)'",
    "lint:safe": "next lint 2>&1 || echo 'Lint warnings found (non-blocking)'",
    "build:netlify:safe": "pnpm contentlayer:build && pnpm build:fast || echo 'Build completed with warnings'",
    "assets:scan": "node scripts/audit-assets.js || echo 'Asset scan complete'",
    "contentlayer2:build": "contentlayer2 build",
    "validate": "pnpm typecheck && pnpm lint && pnpm test",
    "upgrade:interactive": "npm-check --update",
    "upgrade:all": "pnpm update --latest",
    "dedupe": "pnpm dedupe",
    "why": "pnpm why",
    "outdated": "pnpm outdated",
    "doctor": "pnpm doctor",
    "cache:clear": "pnpm store prune",
    "reinstall": "pnpm clean:all && rimraf node_modules pnpm-lock.yaml && pnpm install",
    "docker:build": "docker build -t abraham-of-london .",
    "docker:run": "docker run -p 3000:3000 abraham-of-london",
    "docker:compose": "docker-compose up",
    "stats": "pnpm pdf:stats && pnpm assets:metrics && pnpm vault:audit",
    "stats:full": "pnpm stats && node scripts/generate-full-stats.js",
    "monitor": "node scripts/monitor-system.js",
    "backup": "node scripts/backup-assets.js",
    "restore": "node scripts/restore-assets.js",
    "init": "pnpm install && pnpm db:generate && pnpm contentlayer:build",
    "init:full": "pnpm init && pnpm pdf:build:full && pnpm assets:enterprise",
    "help": "node scripts/help.js",
    "version:check": "node scripts/check-versions.js",
    "update:scripts": "node scripts/update-scripts.js"

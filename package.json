    "test:decision": "vitest run lib/decision/__tests__/ --reporter=verbose",
    "test:decision:watch": "vitest watch lib/decision/__tests__/",
    "test:performance": "vitest run tests/performance --runInBand",
    "test:integration": "vitest run tests/integration --runInBand",
    "test:coverage": "vitest run --coverage",
    "test:coverage:html": "vitest run --coverage --reporter=html",

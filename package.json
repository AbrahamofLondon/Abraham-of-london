    "vault:glossary": "node scripts/glossary-injector.mjs",
    "vault:check": "node scripts/build-manifest.mjs && node scripts/validate-links.mjs",
    "vault:manifest": "node scripts/generate-vault-manifest.mjs",
    "vault:deploy": "pnpm vault:audit && pnpm vault:sync && next build --webpack",
    "vault:ready": "pnpm contentlayer:safe && pnpm vault:audit && pnpm vault:glossary && pnpm vault:check && pnpm vault:manifest",
    "vault:dry": "node scripts/vault-repair-dry.mjs",
    "vault:sign": "tsx scripts/sign-vault.ts",
    "vault:generate": "tsx --env-file=.env.local scripts/batch-gen.ts",
    "vault:build": "pnpm vault:generate",
    "assets:optimize": "node scripts/optimize-assets.js",
    "assets:enterprise": "tsx scripts/enterprise-asset-optimizer.ts",
    "assets:enterprise:production": "cross-env NODE_ENV=production tsx scripts/enterprise-asset-optimizer.ts --quality=premium",
    "assets:audit": "node scripts/audit-assets.js",
    "assets:metrics": "node scripts/analyze-metrics.js",
    "assets:clean": "rimraf public/optimized-* public/fonts/optimized logs metrics .cache/assets",
    "assets:images:optimize": "node scripts/optimize-images.js",
    "optimize:premium": "tsx scripts/enterprise-asset-optimizer.ts --images-only --avif --ultra-quality",
    "assets:fonts:generate": "node scripts/generate-fonts.cjs",
    "pdf:build:full": "pnpm pdf:registry:full && pnpm pdf:generate-all && pnpm pdf:sync",
    "pdf:generate-all": "tsx scripts/pdf/unified-pdf-generator.ts --scan-content --generate --use-puppeteer --use-universal --overwrite --strict --concurrency 1 --soffice \"C:\\Program Files\\LibreOffice\\program\\soffice.com\"",

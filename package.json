    "db:sync:prisma": "pnpm db:generate && pnpm db:push && pnpm db:seed",
    "db:sync:sqlite": "pnpm db:sqlite:setup && pnpm db:sqlite:migrate && pnpm db:sqlite:seed",
    "db:sync:all": "pnpm db:sync:prisma && pnpm db:sync:sqlite",

    "db:restore": "node scripts/restore-db.js",
    "db:console": "sqlite3 data/app.db",
    "db:validate": "node scripts/validate-db.js",
    "db:stats": "node scripts/db-stats.js",
    "sync": "node scripts/master-sync.mjs",
    "content:normalize": "node scripts/fix-content-whitespace.mjs",
    "prisma:type-gate": "node scripts/prisma-type-gate.mjs",
    "content:build": "contentlayer2 build",

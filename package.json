    "pdf:audit": "pnpm pdf:list && pnpm pdf:validate",
    "pdf:repair": "tsx scripts/pdf/repair-pdfs.ts --repair-empty --regenerate-corrupt",
    "pdf:list": "tsx scripts/pdf/list-pdfs.ts",
    "pdf:ssot:validate": "tsx scripts/pdf/generate-pdfs.ts",
    "pdf:validate": "node scripts/pdf/validate-pdfs.js",

  "scripts": {
    "clean": "rimraf .next .contentlayer node_modules/.cache .cache",
    "dev": "pnpm mdx:gate && pnpm pdf:registry:build && contentlayer2 build && next dev --webpack",
    "dev:full": "pnpm env:check && contentlayer2 build && concurrently --kill-others-on-fail=false --names \"CONTENT,DEV\" \"pnpm contentlayer2:watch\" \"next dev --webpack\"",
    "dev:windows": "cross-env IS_WINDOWS=true contentlayer2 build && next dev --webpack",
    "dev:profile": "cross-env NEXT_PROFILING=true contentlayer2 build && next dev --webpack",
    "start": "next start",
    "preview": "next start --port 3001",
    "prebuild": "pnpm contentlayer2 build && pnpm vault:sync",
    "//": "----- BUILD (PRODUCTION) -----",
    "mdx:gate": "node scripts/mdx-illegal-jsx-gate.mjs",
    "//_mdx": "MDX integrity: fails if upstream scripts escaped/stripped MDX component tags",
    "mdx:integrity": "node scripts/mdx-integrity-check.mjs",
    "generate:epubs": "tsx scripts/generate-all-epubs.ts",
    "build": "pnpm generate:epubs && next build --webpack",
    "build:ci": "pnpm prebuild:ci && pnpm build",
    "//_netlify": "Netlify should NOT rebuild everything twice. Make it explicit and single-pass.",
    "build:netlify": "pnpm mdx:gate && pnpm contentlayer:clean && pnpm mdx:integrity && pnpm build:fast",
    "build:safe": "pnpm vault:fix && pnpm fix:encoding && pnpm content:validate && pnpm build",
    "build:fast": "tsx scripts/build-pdf-registry-json.ts && cross-env NODE_OPTIONS=\"--max-old-space-size=7168\" NEXT_TELEMETRY_DISABLED=1 bash -c 'set -o pipefail; next build --webpack 2>&1 | tee /tmp/nextbuild.log'",
    "build:verbose": "cross-env DEBUG=* pnpm build",
    "test:perimeter": "bash ./scripts/perimeter-check.sh",
    "audit:check": "tsc --noEmit ./lib/audit/audit-logger.ts ./lib/inner-circle/exports.server.ts ./lib/server/cron.ts",
    "build:analyze": "cross-env ANALYZE=true pnpm build",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "prebuild:ci": "pnpm vault:fix && pnpm fix:yaml && pnpm fix:windows && pnpm vault:ready",
    "build:pdfs:clean": "node -e \"console.log('build:pdfs:clean disabled (registry is committed)')\"",
    "build:pdfs": "node -e \"console.log('build:pdfs disabled (run pnpm pdf:build:full manually if needed)')\"",
    "build:downloads": "tsx scripts/refresh-downloads.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "db:status": "prisma migrate status",
    "db:sqlite:setup": "node scripts/setup-sqlite.js",
    "db:sqlite:migrate": "tsx scripts/run-migrations.ts up",
    "db:sqlite:status": "tsx scripts/run-migrations.ts status",
    "db:sqlite:reset": "tsx scripts/run-migrations.ts reset",
    "db:sqlite:seed": "tsx prisma/seed-sqlite.ts",
    "db:sqlite:studio": "npx sqlite-viz data/app.db",
    "db:init": "pnpm db:sqlite:setup && pnpm db:sqlite:migrate && pnpm db:sqlite:seed",
    "db:refresh": "pnpm db:sqlite:reset && pnpm db:sqlite:migrate && pnpm db:sqlite:seed",
    "postinstall": "prisma generate",

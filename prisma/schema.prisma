/// Boardroom Dossier — client-facing restricted delivery record.
/// Generated from an IntelligenceSpine via the ER → Boardroom bridge.
/// Access-gated, lineage-tracked, and revocable.
model BoardroomDossier {
  id                 String   @id @default(cuid())
  spineId            String
  title              String
  classification     String   @default("BOARD_RESTRICTED")
  qualifiedForBoard  Boolean  @default(false)
  gateMessage        String?
  sections           Json     @default("[]")
  objectionHandling  Json     @default("[]")
  decisionPath       Json     @default("[]")
  status             String   @default("DRAFT") // DRAFT | APPROVED | DELIVERED | REVOKED
  generatedById      String
  clientEmail        String?
  clientName         String?
  accessGrantedAt    DateTime?
  accessRevokedAt    DateTime?
  lastViewedAt       DateTime?
  viewCount          Int      @default(0)
  // Source provenance — required for real delivery (not sample/synthetic)
  sourceType         String   @default("MANUAL_SYNTHETIC_SAMPLE") // EXECUTIVE_REPORT | DIAGNOSTIC_RUN | ER_BOARDROOM_BRIDGE_RUN | MANUAL_SYNTHETIC_SAMPLE
  sourceId           String?  // ID of source record (ExecutiveReport, DiagnosticJourney, etc.)
  isSample           Boolean  @default(false)
  // Delivery provenance hashes — written by assertPaidDeliveryAuthorised() enforcement
  orderId            String?  // FK to BoardroomBriefOrder.id when sourced from paid order
  inputSnapshotHash  String?  // SHA-256 of input object at generation time
  artifactHash       String?  // SHA-256 of generated dossier JSON
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accessTokens       BoardroomDossierAccessToken[]

  @@index([status])
  @@index([clientEmail])
  @@index([sourceType])
  @@index([createdAt])
}

/// Decision Action Log — converts ER/Boardroom findings into trackable action items.
/// This is the retention hook. Every finding becomes an action item with status, owner, and outcome.
model DecisionActionLog {
  id                String   @id @default(cuid())
  reportId          String
  clientEmail       String
  finding           String
  severity          String   @default("MEDIUM")
  recommendedAction String
  status            String   @default("open") // open | in_progress | actioned | deferred
  owner             String?
  dueDate           DateTime?
  outcomeNote       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientEmail])
  @@index([reportId])
  @@index([status])
  @@index([severity])
}

/// Stripe webhook event tracking for idempotent payment processing.

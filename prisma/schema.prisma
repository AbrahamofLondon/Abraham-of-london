// ============================================================================
// CONTENT & KNOWLEDGE MODELS
// ============================================================================

model ContentMetadata {
  id               String      @id @default(cuid())
  slug             String      @unique
  title            String
  contentType      ContentType @default(Briefs)
  summary          String?
  content          String?
  metadata         String?     @default("{}")
  version          String      @default("1.0.0")
  totalPrints      Int         @default(0)
  engagementScore  Float       @default(0.0)
  downloadCount    Int         @default(0)
  viewCount        Int         @default(0)
  fileSize         Int?
  pageCount        Int?
  pdfPath          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  lastDownloadedAt DateTime?
  lastViewedAt     DateTime?
  classification   AccessTier  @default(client)

  canonEntries    CanonEntry[]
  sourceRelations ContentRelation[]      @relation("SourceRelations")
  targetRelations ContentRelation[]      @relation("TargetRelations")
  downloadEvents  DownloadAuditEvent[]   @relation("ContentDownloadEvents")
  frameworkAccess FrameworkAccessLog[]   @relation("ContentFrameworkAccess")
  premiumTokens   PremiumDownloadToken[]
  annotations     PrivateAnnotation[]
  dependencies    StrategicLink[]        @relation("SourceBrief")
  dependents      StrategicLink[]        @relation("TargetBrief")

  @@index([slug])
  @@index([classification])
  @@index([contentType])
  @@map("content_metadata")
}

model Framework {
  id               String               @id @default(cuid())
  slug             String               @unique
  title            String
  description      String?
  oneLiner         String?
  tag              String?
  accent           String?
  canonRoot        String?
  audience         String?              @default("[]")
  tier             AccessTier           @default(member)
  pdfPath          String
  fileSize         Int?
  pageCount        Int?
  version          String               @default("1.0.0")
  content          String?
  artifactUrl      String?
  viewCount        Int                  @default(0)
  downloadCount    Int                  @default(0)
  lastViewedAt     DateTime?
  lastDownloadedAt DateTime?
  isActive         Boolean              @default(true)
  metadata         String?              @default("{}")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  downloadEvents   DownloadAuditEvent[] @relation("FrameworkDownloadEvents")
  accessLogs       FrameworkAccessLog[] @relation("FrameworkAccess")

  @@index([slug])
  @@map("frameworks")
}

model StrategicLink {
  id          String          @id @default(cuid())
  sourceId    String
  targetId    String
  strength    Float           @default(1.0)
  linkType    LinkType        @default(DEPENDENCY)
  createdAt   DateTime        @default(now())
  sourceBrief ContentMetadata @relation("SourceBrief", fields: [sourceId], references: [id], onDelete: Cascade)
  targetBrief ContentMetadata @relation("TargetBrief", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("strategic_links")
}

model ContentRelation {
  id           String          @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String
  weight       Float           @default(1.0)
  createdAt    DateTime        @default(now())
  source       ContentMetadata @relation("SourceRelations", fields: [sourceId], references: [id], onDelete: Cascade)
  target       ContentMetadata @relation("TargetRelations", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@map("content_relations")
}

model PrivateAnnotation {
  id        String             @id @default(cuid())
  body      String
  priority  AnnotationPriority @default(ROUTINE)
  contentId String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  memberId  String
  content   ContentMetadata    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  member    InnerCircleMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("private_annotations")
}

model CanonEntry {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String?
  contentType String
  readTime    Int?
  metadataId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tier        AccessTier       @default(member)
  metadata    ContentMetadata? @relation(fields: [metadataId], references: [id])

  @@map("canon_entries")
}

model StrategicFramework {
  id          String     @id @default(cuid())
  key         String     @unique
  slug        String     @unique
  title       String
  oneLiner    String
  tag         String
  accent      String
  canonRoot   String
  audience    String     @default("[]")
  content     String?
  artifactUrl String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tier        AccessTier @default(member)

  @@index([slug])
  @@map("strategic_frameworks")
}

model StrategicIntervention {
  id             String    @id @default(cuid())
  organisationId String
  campaignId     String?
  domain         String
  baselineScore  Int
  status         String    @default("PENDING")
  deployedAt     DateTime?
  createdAt      DateTime  @default(now())

  organisation    Organisation       @relation(fields: [organisationId], references: [id])
  campaign        AlignmentCampaign? @relation(fields: [campaignId], references: [id])
  correctionNodes CorrectionNode[]

  @@index([organisationId])
  @@index([campaignId])
  @@index([status])
}

model CorrectionNode {
  id             String   @id @default(cuid())
  interventionId String
  campaignId     String?
  title          String
  description    String
  priority       String   @default("MEDIUM")
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())

  intervention StrategicIntervention @relation(fields: [interventionId], references: [id])
  campaign     AlignmentCampaign?    @relation(fields: [campaignId], references: [id])

  @@index([interventionId])
}

model DecisionAssetGovernanceRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assetId      String?
  assetKind    String?
  ruleType     String
  contextType  String?
  contextValue String?

  minConfidenceScore  Float?
  minContextualWeight Float?
  maxContextualWeight Float?
  minImpressions      Int?
  suppress            Boolean @default(false)
  priorityPenalty     Float   @default(0)
  priorityBoost       Float   @default(0)

  rationale String?
  metadata  String?

  @@index([assetId])
  @@index([assetKind])
  @@index([contextType, contextValue])
  @@index([ruleType])
}

// ============================================================================
// DOWNLOAD & ASSET MODELS
// ============================================================================

model DownloadAuditEvent {
  id                String               @id @default(cuid())
  slug              String
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime             @default(now())
  emailHash         String?
  ipHash            String?
  latencyMs         Int
  metadata          String?              @default("{}")
  processedAt       DateTime
  success           Boolean
  memberId          String?
  errorCode         String?
  errorDetail       String?
  referrer          String?
  statusCode        Int?
  eventType         DownloadEventType    @default(PREVIEW)
  contentId         String?
  deliveredChecksum String?
  deliveryMode      DownloadDeliveryMode @default(DIRECT)
  email             String?
  fileHash          String?
  fileName          String?
  fileSize          BigInt?
  frameworkId       String?
  printAssetId      String?
  requestId         String?
  sessionId         String?
  sourceChecksum    String?
  title             String?
  watermarkId       String?
  contentType       DownloadContentType
  content           ContentMetadata?     @relation("ContentDownloadEvents", fields: [contentId], references: [id])
  framework         Framework?           @relation("FrameworkDownloadEvents", fields: [frameworkId], references: [id])
  member            InnerCircleMember?   @relation("MemberDownloadEvents", fields: [memberId], references: [id])
  printAsset        PrintAsset?          @relation("PrintDownloadEvents", fields: [printAssetId], references: [id])

  @@index([slug])
  @@index([createdAt])
  @@map("download_audit_events")
}

model PrintAsset {
  id          String               @id @default(cuid())
  slug        String               @unique
  title       String
  description String?
  filePath    String
  fileSize    Int?
  fileFormat  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tier        AccessTier           @default(member)
  downloads   DownloadAuditEvent[] @relation("PrintDownloadEvents")

  @@index([slug])
  @@map("print_assets")
}

model PremiumDownloadToken {
  id           String                   @id @default(cuid())
  tokenId      String                   @unique
  contentId    String
  userId       String?
  sessionId    String?
  tier         String?
  issuedAt     DateTime                 @default(now())
  expiresAt    DateTime
  maxDownloads Int                      @default(1)
  usedCount    Int                      @default(0)
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  metadata     String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  attempts     PremiumDownloadAttempt[]
  content      ContentMetadata          @relation(fields: [contentId], references: [slug], onDelete: Cascade)
  user         InnerCircleMember?       @relation(fields: [userId], references: [id])

  @@index([tokenId])
  @@map("premium_download_tokens")
}

model PremiumDownloadAttempt {
  id                 String                @id @default(cuid())
  tokenId            String?
  contentId          String
  userId             String?
  sessionId          String?
  ipAddress          String?
  ipHash             String?
  userAgent          String?
  referrer           String?
  method             String?
  success            Boolean
  statusCode         Int
  reason             String?
  watermarkId        String?
  sourceChecksum     String?
  deliveredChecksum  String?
  createdAt          DateTime              @default(now())
  downloadDuration   Int?
  fileSize           Int?
  pageCount          Int?
  requiredTier       String?
  userTier           String?
  requestFingerprint String?
  token              PremiumDownloadToken? @relation(fields: [tokenId], references: [tokenId])

  @@index([createdAt])
  @@map("premium_download_attempts")
}

model FrameworkAccessLog {
  id           String             @id @default(cuid())
  slug         String
  memberId     String?
  accessType   AccessType         @default(VIEW)
  decision     String
  allowed      Boolean
  requiredTier AccessTier?
  currentTier  AccessTier?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime           @default(now())
  contentId    String?
  frameworkId  String?
  requestId    String?
  sessionId    String?
  content      ContentMetadata?   @relation("ContentFrameworkAccess", fields: [contentId], references: [id])
  framework    Framework?         @relation("FrameworkAccess", fields: [frameworkId], references: [id])
  member       InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([slug])
  @@map("framework_access_logs")
}

// ============================================================================
// DECISION JOURNEY INSTRUMENTATION (Brief C)
// ============================================================================

model DecisionJourneyEvent {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  stage     String
  context   String?  // JSON: bundleId, entryPath, buyerState, evidenceDepth, escalationLevel
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([stage])
  @@index([createdAt])
  @@map("decision_journey_events")
}

// ============================================================================
// STRATEGY ROOM EXECUTION (Brief D)
// ============================================================================

model StrategyRoomExecutionSession {
  id                    String   @id @default(cuid())
  sessionKey            String   @unique
  strategyRoomSessionId String?
  userId                String?
  email                 String?

  // Entry state
  directive        String?  // allow | warn | restrict | block
  escalationLevel  String?
  conditionSummary String?

  // Decision frame
  coreProblem      String?
  decisionQuestion String?
  constraints      String?  // JSON array
  exposureLevel    String?

  // Intervention stack
  interventionStack String?  // JSON: InterventionStep[]

  // Constraint map
  constraintMap String?  // JSON: authority gaps, resource constraints, stakeholder resistance

  // Canonical snapshot from Strategy Room
  canonicalSnapshot String?

  status    String   @default("active")  // active | completed | escalated | monitoring
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decisions StrategyDecisionLog[]

  @@index([email])
  @@index([status])
  @@map("strategy_room_execution_sessions")
}

model StrategyDecisionLog {
  id             String    @id @default(cuid())
  sessionId      String
  decision       String
  status         String    @default("pending")  // pending | executed | blocked | escalated | failed
  notes          String?
  deadline       DateTime?
  avoidanceCount Int       @default(0)
  executedAt     DateTime?
  escalatedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  session StrategyRoomExecutionSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([status])
  @@map("strategy_decision_logs")
}

// ============================================================================
// COMMERCIAL RECOVERY
// ============================================================================

model FailedEntitlementGrant {
  id        String   @id @default(cuid())
  email     String
  slug      String
  source    String
  error     String
  resolved  Boolean  @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([resolved])
  @@map("_failed_entitlement_grants")
}

// ============================================================================
// DURABLE ENFORCEMENT (Strategy Room)
// ============================================================================

model ConsequenceTimeline {
  id        String   @id @default(cuid())
  sessionId String
  score     Int
  label     String
  trend     String   // STABLE | ESCALATING | CRITICAL
  baseRisk  Int      @default(0)
  timePenalty Int    @default(0)
  failurePenalty Int @default(0)
  explanation String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@map("consequence_timeline")
}

model EscalationEvent {
  id          String   @id @default(cuid())
  sessionId   String
  triggerType String   // DEADLINE_EXCEEDED | ACTIONS_SKIPPED | BLOCKED_WITHOUT_REASON | REPEATED_AVOIDANCE
  message     String
  decisionId  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@map("escalation_events")
}

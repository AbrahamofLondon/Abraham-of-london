generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

/**
 * ============================================================================
 * ORG / MULTI-TENANCY
 * ============================================================================
 */

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  status    String   @default("active")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invites OrganizationInvite[]
  members OrganizationMember[]

  @@index([slug])
  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id             String @id @default(cuid())
  organizationId String
  memberId       String @db.Uuid

  role        MemberRole   @default(MEMBER)
  status      MemberStatus @default(active)
  permissions Permission[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member       InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, memberId])
  @@index([organizationId])
  @@index([memberId])
  @@map("organization_members")
}

model OrganizationInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  tokenHash      String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  metadata       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
  @@map("organization_invites")
}

/**
 * ============================================================================
 * CORE MEMBER
 * ============================================================================
 */

model InnerCircleMember {
  // ✅ MUST be UUID to match DB + all FK columns
  id String @id @map("id") @db.Uuid

  emailHash String  @unique(map: "inner_circle_members_emailHash_key") @map("email_hash")
  email     String? @unique @map("email")
  name      String? @map("name")

  role   MemberRole   @default(MEMBER) @map("role")
  tier   AccessTier   @default(member) @map("tier")
  status MemberStatus @default(active) @map("status")

  viewCount  Int      @default(0) @map("view_count")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  flags           String?      @map("flags")
  permissions     Permission[] @default([]) @map("permissions")
  emailHashPrefix String?      @map("email_hash_prefix")
  lastIp          String?      @map("last_ip")

  // Relations (make Prisma Client usable)
  adminSessions  AdminSession[]
  orgMemberships OrganizationMember[]

  sessions     Session[]
  keys         InnerCircleKey[]
  apiKeys      ApiKey[]
  apiLogs      ApiLog[]
  pageViews    PageView[]
  securityLogs SecurityLog[]

  annotations     PrivateAnnotation[]
  inquiries       StrategyInquiry[]
  strategyIntakes StrategyIntake[]
  downloadEvents  DownloadAuditEvent[] @relation("MemberDownloads")

  preferences UserPreference?
  MfaSetup    MfaSetup?

  @@index([status])
  @@index([tier])
  @@index([role])
  @@index([lastSeenAt])
  @@index([lastSeenAt], map: "inner_circle_members_lastSeenAt_idx")
  @@map("inner_circle_members")
}

/**
 * ============================================================================
 * CONTENT GRAPH
 * ============================================================================
 */

model ContentMetadata {
  id              String                 @id @default(cuid())
  slug            String                 @unique
  title           String
  contentType     ContentType            @default(Briefing)
  classification  AccessTier             @default(client)
  summary         String?
  content         String?
  metadata        Json?                  @default("{}")
  version         String                 @default("1.0.0")
  embedding       Unsupported("vector")?
  totalPrints     Int                    @default(0)
  engagementScore Float                  @default(0.0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  canonEntries    CanonEntry[]
  sourceRelations ContentRelation[]   @relation("SourceRelations")
  targetRelations ContentRelation[]   @relation("TargetRelations")
  annotations     PrivateAnnotation[]
  dependencies    StrategicLink[]     @relation("SourceBrief")
  dependents      StrategicLink[]     @relation("TargetBrief")

  @@index([slug])
  @@index([classification])
  @@index([contentType])
  @@map("content_metadata")
}

model StrategicLink {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  strength  Float    @default(1.0)
  linkType  LinkType @default(DEPENDENCY)
  createdAt DateTime @default(now())

  sourceBrief ContentMetadata @relation("SourceBrief", fields: [sourceId], references: [id], onDelete: Cascade)
  targetBrief ContentMetadata @relation("TargetBrief", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
  @@index([linkType])
  @@map("strategic_links")
}

model ContentRelation {
  id           String   @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String
  weight       Float    @default(1.0)
  createdAt    DateTime @default(now())

  source ContentMetadata @relation("SourceRelations", fields: [sourceId], references: [id], onDelete: Cascade)
  target ContentMetadata @relation("TargetRelations", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId])
  @@index([targetId])
  @@map("content_relations")
}

model PrivateAnnotation {
  id        String                 @id @default(cuid())
  body      String
  priority  AnnotationPriority     @default(ROUTINE)
  memberId  String                 @db.Uuid
  contentId String
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  content ContentMetadata   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  member  InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([contentId])
  @@index([priority])
  @@map("private_annotations")
}

/**
 * ============================================================================
 * STRATEGY ROOM
 * ============================================================================
 */

model StrategyInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  intent    String
  status    InquiryStatus @default(PENDING)
  metadata  Json?         @default("{}")
  memberId  String?       @db.Uuid
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  member InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([memberId])
  @@map("strategy_inquiries")
}

model StrategyIntake {
  id              String   @id @default(cuid())
  fullName        String
  organisation    String
  dependencyLevel String
  volatility      String
  readinessScore  Int      @default(5)
  payload         Json
  memberId        String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  emailHash       String?

  member InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([organisation])
  @@index([createdAt])
  @@index([memberId])
  @@map("strategy_intakes")
}

/**
 * ============================================================================
 * SYSTEM CONFIG / AUDIT / SECURITY
 * ============================================================================
 */

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("system_configs")
}

model SystemAuditLog {
  id       String        @id @default(cuid())
  action   String
  severity AuditSeverity @default(info)

  actorId    String?
  actorEmail String?
  resourceId String?

  ipAddress String?
  userAgent String?

  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())

  actorType    String? @default("system") @map("actor_type") @db.VarChar(32)
  status       String? @default("success") @map("status") @db.VarChar(16)
  resourceType String? @map("resource_type") @db.VarChar(64)
  resourceName String? @map("resource_name") @db.VarChar(256)
  requestId    String? @map("request_id") @db.VarChar(128)
  sessionId    String? @map("session_id") @db.VarChar(128)
  durationMs   Int?    @map("duration_ms")
  errorMessage String? @map("error_message")
  category     String? @map("category") @db.VarChar(64)
  subCategory  String? @map("sub_category") @db.VarChar(128)
  tags         Json?   @default("[]") @map("tags")

  @@index([action])
  @@index([severity])
  @@index([actorId])
  @@index([resourceId])
  @@index([createdAt])
  @@index([actorType])
  @@index([status])
  @@index([category])
  @@index([requestId])
  @@index([sessionId])
  @@map("system_audit_logs")
}

model SecurityLog {
  id       String        @id @default(cuid())
  event    SecurityEvent
  severity AuditSeverity @default(info)

  memberId String?            @db.Uuid
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  action    String
  details   Json?    @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([severity])
  @@index([memberId])
  @@index([createdAt])
  @@map("security_logs")
}

/**
 * ============================================================================
 * API LOGS / SESSIONS / KEYS / MFA
 * ============================================================================
 */

model ApiLog {
  id             String     @id @default(cuid())
  endpoint       String
  method         HttpMethod
  statusCode     Int
  responseTimeMs Int        @default(0)
  ipAddress      String?
  userAgent      String?
  actorId        String?
  actorEmail     String?
  metadata       Json?      @default("{}")
  createdAt      DateTime   @default(now())

  memberId String?            @db.Uuid
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([endpoint])
  @@index([method])
  @@index([statusCode])
  @@index([createdAt])
  @@index([memberId])
  @@map("api_logs")
}

model Session {
  id        String @id @default(cuid())
  sessionId String @unique

  memberId String?            @db.Uuid
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  status    SessionStatus @default(active)
  expiresAt DateTime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([memberId])
  @@index([expiresAt])
  @@index([status])
  @@map("sessions")
}

model InnerCircleKey {
  id            String    @id @default(cuid())
  keyHash       String    @unique
  status        KeyStatus @default(active)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime
  keySuffix     String?   @db.VarChar(8)
  keyType       String
  lastUsedAt    DateTime?
  metadata      Json?     @default("{}")
  revokedAt     DateTime?
  revokedReason String?

  memberId String            @db.Uuid
  member   InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([keyHash])
  @@index([status])
  @@index([expiresAt])
  @@map("inner_circle_keys")
}

model MfaSetup {
  id     String @id @default(cuid())
  userId String @unique @db.Uuid

  member InnerCircleMember @relation(fields: [userId], references: [id], onDelete: Cascade)

  enabled       Boolean     @default(false)
  methods       MfaMethod[] @default([totp])
  totpSecret    String?
  totpVerified  Boolean     @default(false)
  backupCodes   Json?       @default("[]")
  phoneNumber   String?
  phoneVerified Boolean     @default(false)
  emailVerified Boolean     @default(false)
  recoveryEmail String?
  lastUsedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([enabled])
  @@map("mfa_setups")
}

/**
 * ============================================================================
 * CONTENT REGISTRY / PRINTS / DOWNLOAD EVENTS
 * ============================================================================
 */

model StrategicFramework {
  id          String     @id @default(cuid())
  key         String     @unique
  slug        String     @unique
  title       String
  oneLiner    String
  tag         String
  accent      String
  canonRoot   String
  audience    String[]
  tier        AccessTier @default(member)
  content     String?
  artifactUrl String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tier])
  @@index([slug])
  @@map("strategic_frameworks")
}

model PrintAsset {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String?
  tier        AccessTier @default(member)
  filePath    String
  fileSize    Int?
  fileFormat  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  downloads DownloadAuditEvent[] @relation("PrintDownloads")

  @@index([tier])
  @@index([slug])
  @@map("print_assets")
}

model CanonEntry {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String?
  tier        AccessTier       @default(member)
  contentType String
  readTime    Int?
  metadataId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  metadata    ContentMetadata? @relation(fields: [metadataId], references: [id], onDelete: SetNull)

  @@index([tier])
  @@index([contentType])
  @@map("canon_entries")
}

model DownloadAuditEvent {
  id   String @id @default(cuid())
  slug String

  printAssetId String?
  printAsset   PrintAsset? @relation("PrintDownloads", fields: [printAssetId], references: [id], onDelete: SetNull)

  memberId String?            @db.Uuid
  member   InnerCircleMember? @relation("MemberDownloads", fields: [memberId], references: [id], onDelete: SetNull)

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // option-2 security fields (your DB has these)
  contentType String?   @db.VarChar(64)
  eventType   String?   @db.VarChar(32)
  fileHash    String?   @db.VarChar(128)
  processedAt DateTime?
  success     Boolean   @default(true)

  @@index([slug])
  @@index([memberId])
  @@index([printAssetId])
  @@index([createdAt])
  @@index([eventType])
  @@index([success])
  @@index([processedAt])
  @@map("download_audit_events")
}

/**
 * ============================================================================
 * API KEYS / ANALYTICS
 * ============================================================================
 */

model ApiKey {
  id         String       @id @default(cuid())
  name       String
  keyHash    String       @unique
  tier       AccessTier   @default(member)
  rateLimit  Int          @default(100)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  metadata   Json?        @default("{}")
  scopes     String[]     @default([])
  status     ApiKeyStatus @default(active)

  memberId String?            @db.Uuid
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([keyHash])
  @@index([tier])
  @@index([status])
  @@index([expiresAt])
  @@index([memberId])
  @@map("api_keys")
}

model PageView {
  id   String  @id @default(cuid())
  path String
  slug String?

  memberId String?            @db.Uuid
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  requiredTier AccessTier?
  userTier     AccessTier?
  referrer     String?
  userAgent    String?
  ipAddress    String?
  viewedAt     DateTime    @default(now())

  @@index([path])
  @@index([memberId])
  @@index([viewedAt])
  @@map("page_views")
}

model UserPreference {
  id String @id @default(cuid())

  memberId String            @unique @db.Uuid
  member   InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  theme              String?   @default("dark")
  emailNotifications Boolean   @default(true)
  digestFrequency    String?
  bookmarks          Json?     @default("[]")
  lastReadAt         DateTime?
  updatedAt          DateTime  @updatedAt

  @@map("user_preferences")
}

/**
 * ============================================================================
 * OPS: WEBHOOKS / EVENTS / JOBS / ADMIN SESSIONS
 * ============================================================================
 */

model WebhookEndpoint {
  id         String            @id @default(cuid())
  name       String
  url        String
  secret     String?
  status     WebhookStatus     @default(active)
  eventTypes String[]          @default([])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]

  @@index([status])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String    @id @default(cuid())
  endpointId  String
  eventType   String
  payload     Json
  statusCode  Int?
  ok          Boolean   @default(false)
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

model SystemEvent {
  id          String    @id @default(cuid())
  eventType   String
  payload     Json
  source      String?
  status      String    @default("pending")
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("system_events")
}

model Job {
  id          String    @id @default(cuid())
  queue       String    @default("default")
  type        String
  payload     Json      @default("{}")
  status      String    @default("queued")
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  runAfter    DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([queue])
  @@index([status])
  @@index([runAfter])
  @@map("jobs")
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  metadata  Json?    @default("{}")

  userId String            @db.Uuid
  user   InnerCircleMember @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@index([userId])
  @@map("admin_sessions")
}

/**
 * ============================================================================
 * ENUMS
 * ============================================================================
 */

enum AccessTier {
  public
  member
  inner_circle
  client
  legacy
  architect
  owner

  @@map("access_tier")
}

enum MemberRole {
  ADMIN
  PRINCIPAL
  DELEGATE
  MEMBER

  @@map("member_role")
}

enum MemberStatus {
  active
  paused
  disabled
  suspended

  @@map("member_status")
}

enum Permission {
  content_read
  content_write
  content_publish
  downloads_read
  downloads_premium
  inner_circle_access
  inner_circle_issue_keys
  inner_circle_revoke_keys
  admin_all
  billing_read
  billing_write
  system_config_write
  security_read
  security_write
  security_revoke_sessions

  @@map("permission")
}

enum ContentType {
  Dossier
  Briefing
  Operational_Framework
  Lexicon
  Landing

  @@map("content_type")
}

enum LinkType {
  PREREQUISITE
  COMPLEMENTARY
  DEPENDENCY

  @@map("link_type")
}

enum AnnotationPriority {
  ROUTINE
  URGENT
  MANDATE

  @@map("annotation_priority")
}

enum InquiryStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CLOSED

  @@map("inquiry_status")
}

enum AuditSeverity {
  info
  warning
  high
  critical

  @@map("audit_severity")
}

enum SecurityEvent {
  login_success
  login_failed
  logout
  session_revoked
  session_expired
  mfa_challenge_created
  mfa_verified
  mfa_failed
  mfa_max_attempts
  key_redeemed
  key_revoked
  key_expired
  admin_action

  @@map("security_event")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  OPTIONS
  HEAD

  @@map("http_method")
}

enum KeyStatus {
  active
  revoked
  expired

  @@map("key_status")
}

enum SessionStatus {
  active
  revoked
  expired

  @@map("session_status")
}

enum MfaMethod {
  totp
  sms
  email
  backup_code
  push

  @@map("mfa_method")
}

enum ApiKeyStatus {
  active
  revoked
  expired

  @@map("api_key_status")
}

enum WebhookStatus {
  active
  disabled

  @@map("webhook_status")
}

// ============================================================================
// ORGANISATION & ENTERPRISE CAMPAIGN SYSTEM
// ============================================================================

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sector    String?
  sizeBand  String?
  region    String?
  status    String   @default("active")
  metadata  String?  @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   OrganisationMembership[]
  campaigns     AlignmentCampaign[]
  invites       OrganisationInvite[]
  interventions StrategicIntervention[]
  snapshots     AlignmentSnapshot[]
  retainerContracts RetainerContract[]

  @@index([name])
  @@index([status])
  @@index([slug])
}

model AlignmentCampaign {
  id                    String    @id @default(cuid())
  organisationId        String
  title                 String
  objective             String?
  status                String    @default("draft")
  stage                 String    @default("intake")
  diagnosticType        String    @default("enterprise")
  opensAt               DateTime?
  closesAt              DateTime?
  cadenceType           String    @default("ad_hoc")
  createdByMembershipId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  metadata              String?   @default("{}")

  organisation        Organisation            @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdByMembership OrganisationMembership? @relation("CampaignCreatedByMembership", fields: [createdByMembershipId], references: [id])

  correctionNodes        CorrectionNode[]
  participants           CampaignParticipant[]
  assessments            EnterpriseAssessment[]
  auditResponses         AuditResponse[]
  teamSnapshots          TeamAssessmentSnapshot[]
  organisationSnapshots  OrganisationAssessmentSnapshot[]
  constitutionalIntakes  ConstitutionalIntakeReport[]
  executiveRuns          ExecutiveReportingRun[]
  leadershipGapSnapshots LeadershipGapSnapshot[]
  reports                EnterpriseReport[]
  interventions          StrategicIntervention[]
  snapshot               AlignmentSnapshot?               @relation("CampaignAlignmentSnapshot")

  @@index([organisationId])
  @@index([status])
  @@index([diagnosticType])
  @@index([stage])
  @@index([opensAt])
  @@index([closesAt])
}

model AlignmentSnapshot {
  id             String   @id @default(cuid())
  campaignId     String   @unique
  organisationId String
  cohortSize     Int
  aggregatedData String
  finalizedAt    DateTime @default(now())

  campaign     AlignmentCampaign @relation("CampaignAlignmentSnapshot", fields: [campaignId], references: [id], onDelete: Cascade)
  organisation Organisation      @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
  @@index([finalizedAt])
}

model OrganisationInvite {
  id             String       @id @default(cuid())
  organisationId String
  email          String
  tokenHash      String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  metadata       String?      @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([email])
  @@index([expiresAt])
  @@index([tokenHash])
  @@map("organisation_invites")
}

model OrganisationMembership {
  id             String   @id @default(cuid())
  organisationId String
  userId         String?
  email          String
  fullName       String?
  roleTitle      String?
  teamName       String?
  functionName   String?
  seniorityBand  String?
  isExecutive    Boolean  @default(false)
  role           String   @default("CONTRIBUTOR")
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  createdCampaigns AlignmentCampaign[]   @relation("CampaignCreatedByMembership")
  participants     CampaignParticipant[]

  @@unique([organisationId, email])
  @@index([organisationId])
  @@index([email])
  @@index([teamName])
  @@index([status])
}

model GovernanceLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  target      String?
  details     String?
  createdAt   DateTime @default(now())
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          UserRole       @default(USER)

  accounts      Account[]

  entitlements  Entitlement[]
  accessKeyUses AccessKeyUse[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Entitlement {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        EntitlementType
  key         String
  status      EntitlementStatus  @default(ACTIVE)

  metadata    Json?

  issuedAt    DateTime           @default(now())
  startsAt    DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  issuedBy    String?
  revokedBy   String?
  reason      String?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId, type, status])
  @@index([key, type, status])
  @@unique([userId, type, key, status], map: "entitlement_active_uniqueness")
}

model AccessKey {
  id            String           @id @default(cuid())
  codeHash       String           @unique
  codePreview    String
  label          String?
  status         AccessKeyStatus  @default(ACTIVE)

  grants         Json
  metadata       Json?

  maxUses        Int              @default(1)
  uses           Int              @default(0)

  startsAt       DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  issuedBy       String?
  revokedBy      String?
  reason         String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  usesLog        AccessKeyUse[]

  @@index([status])
  @@index([expiresAt])
}

model AccessKeyUse {
  id           String     @id @default(cuid())
  accessKeyId  String
  accessKey    AccessKey  @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  redeemedAt   DateTime   @default(now())
  ipAddress    String?
  userAgent    String?

  @@index([accessKeyId])
  @@index([userId])
  @@unique([accessKeyId, userId])
}

model AccessAuditLog {
  id            String         @id @default(cuid())
  actorType     AuditActorType
  actorUserId   String?
  actorEmail    String?

  action        String
  targetType    String
  targetKey     String?

  success       Boolean        @default(true)
  reason        String?
  metadata      Json?

  createdAt     DateTime       @default(now())

  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetKey])
}

model AccessInvite {
  id               String       @id @default(cuid())
  recipientEmail   String
  tokenHash        String       @unique
  grants           Json         // Array<{type, key}>
  status           InviteStatus @default(PENDING)

  issuedBy         String?
  issuedAt         DateTime     @default(now())
  expiresAt        DateTime?

  redeemedByUserId String?
  redeemedAt       DateTime?

  revokedAt        DateTime?
  revokedBy        String?
  reason           String?

  maxUses          Int          @default(1)
  uses             Int          @default(0)
  metadata         Json?

  emailSentAt      DateTime?
  emailError       String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([recipientEmail])
  @@index([status])
  @@index([expiresAt])
  @@map("access_invites")
}

// ============================================================================
// INNER CIRCLE OPERATING LAYER — diagnostic memory and commercial routing
// ============================================================================

model InnerCircleProfile {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  email          String?
  name           String?
  accessState         String   @default("Reader") @map("access_state")
  membershipTier      String   @default("free") @map("membership_tier")
  activePath          String   @default("founder-under-pressure") @map("active_path")
  subscriptionStatus  String   @default("free_trial") @map("subscription_status")
  trialEndsAt         DateTime? @map("trial_ends_at")
  stripeCustomerId    String?  @map("stripe_customer_id")
  subscriptionProductCode String? @map("subscription_product_code")
  subscriptionStartedAt DateTime? @map("subscription_started_at")
  subscriptionCancelledAt DateTime? @map("subscription_cancelled_at")
  metadata            Json?    @map("metadata_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([accessState])
  @@index([membershipTier])
  @@index([subscriptionStatus])
  @@index([activePath])
  @@map("inner_circle_profiles")
}

model InnerCircleDiagnosticResult {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  toolSlug              String   @map("tool_slug")
  pathSlug              String   @map("path_slug")
  answers               Json     @map("answers_json")
  score                 Int
  riskLevel             String   @map("risk_level")
  weakestDomains        Json     @map("weakest_domains_json")
  recommendedNextAction String   @map("recommended_next_action")
  recommendedProduct    String   @map("recommended_product")
  lifecycleStatus       String   @default("completed") @map("lifecycle_status")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([toolSlug])
  @@index([riskLevel])
  @@index([recommendedProduct])
  @@index([createdAt])
  @@map("inner_circle_diagnostic_results")
}

model InnerCircleToolAccess {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  toolSlug     String    @map("tool_slug")
  accessStatus String    @default("granted") @map("access_status")
  accessReason String?   @map("access_reason")
  startsAt     DateTime? @map("starts_at")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([userId, toolSlug])
  @@index([accessStatus])
  @@map("inner_circle_tool_access")
}

model InnerCircleReadingPathProgress {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  pathSlug    String    @map("path_slug")
  status      String    @default("active")
  currentStep Int       @default(0) @map("current_step")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, pathSlug])
  @@index([status])
  @@map("inner_circle_reading_path_progress")
}

model InnerCircleWorksheetAction {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  pathSlug        String    @map("path_slug")
  taskKey         String    @map("task_key")
  task            String
  response        String?
  deadline        DateTime?
  status          String    @default("not_started")
  note            String?
  nextReviewDate  DateTime? @map("next_review_date")
  sortOrder       Int       @default(0) @map("sort_order")
  completedAt     DateTime? @map("completed_at")
  reminderSentAt  DateTime? @map("reminder_sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([userId, pathSlug, taskKey])
  @@index([status])
  @@index([nextReviewDate])
  @@index([deadline])
  @@map("inner_circle_worksheet_actions")
}

model InnerCircleAdvisoryQualification {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  triggerResultId    String?   @map("trigger_result_id")
  status             String    @default("OPEN")
  riskLevel          String    @map("risk_level")
  recommendedProduct String    @map("recommended_product")
  reason             String
  metadata           Json?     @map("metadata_json")
  adminOverride      Boolean   @default(false) @map("admin_override")
  reviewedBy         String?   @map("reviewed_by")
  reviewedAt         DateTime? @map("reviewed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([riskLevel])
  @@index([recommendedProduct])
  @@map("inner_circle_advisory_qualifications")
}

model PressureSignalEvent {
  id                 String   @id @default(cuid())
  userId             String?  @map("user_id")
  inputHash          String   @map("input_hash")
  pressureLevel      String   @map("pressure_level")
  recommendedProduct String   @map("recommended_product")
  safeMetrics        Json     @map("safe_metrics_json")
  result             Json     @map("result_json")
  ipHash             String?  @map("ip_hash")
  userAgent          String?  @map("user_agent")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([pressureLevel])
  @@index([recommendedProduct])
  @@index([createdAt])
  @@map("pressure_signal_events")
}

// ============================================================================
// GLOBAL MARKET INTELLIGENCE — persistent public call ledger and red team queue
// ============================================================================

model GmiCallLedgerEntry {
  id                            String   @id @default(cuid())
  callId                        String   @unique @map("call_id")
  editionId                     String   @map("edition_id")
  editionSlug                   String   @map("edition_slug")
  callStatement                 String   @map("call_statement")
  category                      String
  region                        String?
  assetClass                    String?  @map("asset_class")
  theme                         String?
  originalConfidenceBand        String   @map("original_confidence_band")
  currentStatus                 String   @default("PENDING_REVIEW") @map("current_status")
  currentScore                  Int?     @map("current_score")
  reviewWindowStart             DateTime? @map("review_window_start")
  reviewWindowEnd               DateTime? @map("review_window_end")
  evidenceSummary               String   @default("") @map("evidence_summary")
  evidenceSourceRows            Json     @default("[]") @map("evidence_source_rows_json")
  justification                 String   @default("")
  carryForwardJustification     String?  @map("carry_forward_justification")
  lastReviewedAt                DateTime? @map("last_reviewed_at")
  nextReviewDue                 DateTime? @map("next_review_due")
  methodologyVersion            String   @map("methodology_version")
  rubricVersion                 String   @map("rubric_version")
  immutableOriginalCallSnapshot Json?    @map("immutable_original_call_snapshot_json")
  reviewedBy                    String?  @map("reviewed_by")
  sourceAppendixRefs            Json?    @map("source_appendix_refs_json")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  statusHistory GmiCallLedgerStatusHistory[]

  @@index([editionId])
  @@index([editionSlug])
  @@index([currentStatus])
  @@index([currentScore])
  @@index([nextReviewDue])
  @@map("gmi_call_ledger_entries")
}

model GmiCallLedgerStatusHistory {
  id                  String   @id @default(cuid())
  ledgerEntryId       String   @map("ledger_entry_id")
  callId              String   @map("call_id")
  previousStatus      String?  @map("previous_status")
  newStatus           String   @map("new_status")
  previousScore       Int?     @map("previous_score")
  newScore            Int?     @map("new_score")
  evidenceSummary     String   @default("") @map("evidence_summary")
  evidenceSourceRows  Json     @default("[]") @map("evidence_source_rows_json")
  justification       String   @default("")
  actor               String?  @map("actor")
  requestId           String?  @map("request_id")
  createdAt           DateTime @default(now()) @map("created_at")

  ledgerEntry GmiCallLedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([ledgerEntryId])
  @@index([callId])
  @@index([createdAt])
  @@map("gmi_call_ledger_status_history")
}

model GmiRedTeamSubmission {
  id             String    @id @default(cuid())
  editionId      String?   @map("edition_id")
  callId         String?   @map("call_id")
  submitterName  String    @map("submitter_name")
  submitterEmail String    @map("submitter_email")
  organisation   String?
  counterArgument String   @map("counter_argument")
  evidence       String
  sourceLinks    Json      @default("[]") @map("source_links_json")
  status         String    @default("pending")
  adminNotes     String?   @map("admin_notes")
  publicResponse String?   @map("public_response")
  createdAt      DateTime  @default(now()) @map("created_at")
  reviewedAt     DateTime? @map("reviewed_at")
  reviewedBy     String?   @map("reviewed_by")

  @@index([editionId])
  @@index([callId])
  @@index([status])
  @@index([createdAt])
  @@map("gmi_red_team_submissions")
}

model GmiFalsificationRule {
  id                      String    @id @default(cuid())
  editionId               String    @map("edition_id")
  thesisId                String    @map("thesis_id")
  thesisStatement         String    @map("thesis_statement")
  falsificationCondition  String    @map("falsification_condition")
  observableIndicator     String    @map("observable_indicator")
  thresholdType           String    @map("threshold_type")
  thresholdValue          String    @map("threshold_value")
  currentStatus           String    @default("monitoring") @map("current_status")
  evidenceSourceRows      Json      @default("[]") @map("evidence_source_rows_json")
  nextReviewDue           DateTime? @map("next_review_due")
  lastReviewedAt          DateTime? @map("last_reviewed_at")
  publicExplanation       String?   @map("public_explanation")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@unique([editionId, thesisId])
  @@index([editionId])
  @@index([thesisId])
  @@index([currentStatus])
  @@index([nextReviewDue])
  @@map("gmi_falsification_rules")
}

model GmiPostMortem {
  id                    String    @id @default(cuid())
  editionId             String    @unique @map("edition_id")
  quarter               String
  whatWeGotRight        Json      @default("[]") @map("what_we_got_right_json")
  whatWeGotWrong        Json      @default("[]") @map("what_we_got_wrong_json")
  whatWasTooEarly       Json      @default("[]") @map("what_was_too_early_json")
  whatWeUnderweighted   Json      @default("[]") @map("what_we_underweighted_json")
  whatChangedOurView    Json      @default("[]") @map("what_changed_our_view_json")
  lessonsForNextQuarter Json      @default("[]") @map("lessons_for_next_quarter_json")
  linkedCalls           Json      @default("[]") @map("linked_calls_json")
  publishedAt           DateTime? @map("published_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([editionId])
  @@index([publishedAt])
  @@map("gmi_post_mortems")
}

model GmiEditionGovernanceState {
  id                         String    @id @default(cuid())
  editionId                  String    @unique @map("edition_id")
  publicationStatus          String    @default("draft") @map("publication_status")
  operatorConsequenceIndex   Json      @default("{}") @map("operator_consequence_index_json")
  decisionsToMakeIn30Days    Json      @default("[]") @map("decisions_to_make_in_30_days_json")
  decisionsToPrepareIn90Days Json      @default("[]") @map("decisions_to_prepare_in_90_days_json")
  decisionsToDefer           Json      @default("[]") @map("decisions_to_defer_json")
  boardPulsePublishedAt      DateTime? @map("board_pulse_published_at")
  operatorBriefPublishedAt   DateTime? @map("operator_brief_published_at")
  boardPackGeneratedAt       DateTime? @map("board_pack_generated_at")
  fullEditionGated           Boolean   @default(true) @map("full_edition_gated")
  architectEditionGated      Boolean   @default(true) @map("architect_edition_gated")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  @@index([editionId])
  @@index([publicationStatus])
  @@map("gmi_edition_governance_state")
}

/// GMI Release Snapshot — proves what the system believed at release check time.
/// Created before every publish attempt (blocked or successful).
/// Hashes are deterministic SHA-256 of canonical JSON.
model GmiReleaseSnapshot {
  id                    String   @id @default(cuid())
  editionId             String   @map("edition_id")
  editionSlug           String   @map("edition_slug")

// ─── Intelligence Foundry ─────────────────────────────────────────────────────

model ResearchRun {
  // Identity
  id             String  @id @default(cuid())
  title          String
  slug           String  @unique
  runType        String  // e.g. "RED_TEAM" | "SCENARIO" | "OUTBOUND" | "SECURITY" | "MARKET" | "CONTENT" | "SCHEDULED"
  module         String  // module name from module-registry
  moduleVersion  String  @default("1.0.0")

  // Actor
  actorId    String?
  actorEmail String?

  // Inputs / Outputs
  inputJson    String? // JSON string
  outputJson   String? // JSON string
  baselineJson String? // JSON string for baseline comparison
  findingsJson String? // JSON string — array of Finding objects

  // Actionability
  blockingIssuesJson      String? // JSON string
  dependenciesUnmetJson   String? // JSON string
  recommendation          String?
  severity                String  @default("INFO") // INFO | LOW | MEDIUM | HIGH | CRITICAL
  status                  String  @default("PENDING") // PENDING | IN_PROGRESS | COMPLETE | ACTION_REQUIRED | OWNER_DECISION_REQUIRED | IMPLEMENTED | DEFERRED | ARCHIVED
  estimatedEffort         String?
  requiresOwnerDecision   Boolean @default(false)
  decisionMadeAt          DateTime?
  decisionOutcome         String?
  deferredReason          String?

  // Comparison / Drift
  baselineId   String?
  driftDetected Boolean @default(false)
  driftSummary  String?

  // Security
  exploitabilityScore  Float?
  detectionLikelihood  Float?
  assetAtRisk          String?
  attackVector         String?

  // Market Protection
  claimRisk            String?
  overclaims           String? // JSON string
  forbiddenPhrases     String? // JSON string
  humanReviewRequired  Boolean @default(false)

  // Versioning
  engineVersionJson    String? // JSON string
  referenceVersionJson String? // JSON string
  schemaVersion        String  @default("1.0.0")
  contentFileHash      String?

  // Linkage
  linkedRoute        String?
  linkedRouteExists  Boolean?
  linkedProductId    String?
  linkedFileHash     String?

  // Operations
  runCostEstimate   Float?
  durationMs        Int?
  isDemo            Boolean @default(false)
  resurrectionCount Int     @default(0)
  resurrectedFromId String?

  // Maturity linkage — Phase 3
  // Mirrors EventMaturity from lib/platform/governance-event-types.ts.
  // Only LIVE_GOVERNED runs contribute to product-health GREEN status.
  // SIMULATION_RECORDED runs must have maturityStage = SIMULATION_ONLY.
  maturityStage       String? // RESERVED_CONCEPT | SIMULATION_ONLY | PILOT_READY | LIVE_GOVERNED | RETIRED
  promotionDecision   String? // JSON: { approved, actor, reason, timestamp, criteria[] }
  promotionBlockersJson String? // JSON: string[] — remaining promotion blockers

  // Timestamps
  reviewedAt     DateTime?
  implementedAt  DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  findings         FoundryFinding[]
  auditEvents      FoundryAuditEvent[]
  briefs           ActionBrief[]
  promotions       FoundryPromotion[]
  findingFeedback  FindingFeedback[]

  @@index([module])
  @@index([status])
  @@index([severity])
  @@index([actorId])
  @@index([createdAt])
  @@index([archivedAt])
  @@index([maturityStage])
  @@map("research_runs")
}

model FoundryFinding {
  id            String      @id @default(cuid())
  researchRunId String
  run           ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  findingType    String  // SECURITY | CONTENT | MARKET | FORMULA | STRUCTURAL
  severity       String  // INFO | LOW | MEDIUM | HIGH | CRITICAL
  title          String
  description    String
  source         String  // required — engine name, file path, or audit trail reference
  recommendation String?
  evidence       String? // JSON string
  moduleId       String?

  isActioned Boolean   @default(false)
  actionedAt DateTime?
  actionedBy String?

  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([researchRunId])
  @@index([severity])
  @@index([moduleId])
  @@index([findingType])
  @@index([isActioned])
  @@map("foundry_findings")
}

model FoundryAuditEvent {
  id    String      @id @default(cuid())
  runId String
  run   ResearchRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  event      String  // FOUNDRY_RUN_CREATED | FOUNDRY_RUN_STATUS_CHANGED | etc.
  fromStatus String?
  toStatus   String?
  actorId    String?
  actorEmail String?
  reason     String?
  metadata   String? // JSON string

  createdAt DateTime @default(now())

  @@index([runId])
  @@index([event])
  @@index([createdAt])
  @@map("foundry_audit_events")
}

model ActionBrief {
  id            String      @id @default(cuid())
  researchRunId String
  run           ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  version         Int    @default(1)
  contentHash     String // SHA-256 of briefJson
  briefJson       String // immutable export snapshot
  exportedById    String?
  exportedByEmail String?
  exportedAt      DateTime @default(now())

  @@index([researchRunId])
  @@index([contentHash])
  @@map("action_briefs")
}

model CiGateBlock {
  id             String    @id @default(cuid())
  triggeredBy    String    // actor email or "ci-system"
  blockingRunIds String    // JSON array of ResearchRun IDs
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([createdAt])
  @@index([resolvedAt])
  @@map("ci_gate_blocks")
}

model FoundryPattern {
  id              String   @id @default(cuid())
  patternType     String   // RECURRENCE | ESCALATION | TREND | CLUSTER
  moduleId        String?
  findingType     String?
  occurrenceCount Int      @default(1)
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  severity        String?
  status          String   @default("ACTIVE") // ACTIVE | RESOLVED | SUPPRESSED
  researchRunIds  String   // JSON array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patternType])
  @@index([moduleId])
  @@index([findingType])
  @@index([status])
  @@index([lastSeenAt])
  @@map("foundry_patterns")
}

/// Records a promotion decision between two EventMaturity stages for a product
/// surface or governance event. Created by the promotion workflow after evidence
/// review. Linked to the ResearchRun(s) that served as primary evidence.
model FoundryPromotion {
  id              String      @id @default(cuid())
  eventType       String      // Governance event type or product surface key
  fromStage       String      // RESERVED_CONCEPT | SIMULATION_ONLY | PILOT_READY | LIVE_GOVERNED
  toStage         String      // Target EventMaturity stage
  approvedBy      String      // Actor email who approved the promotion
  approvedAt      DateTime
  promotionReason String
  criteriaMetJson String?     // JSON: string[] — criteria confirmed as met
  blockersJson    String?     // JSON: string[] — remaining blockers at promotion time
  researchRunId   String?     // Primary evidence ResearchRun (optional additional runs via FoundryPattern)
  run             ResearchRun? @relation(fields: [researchRunId], references: [id])
  rollbackAt      DateTime?   // Set if the promotion was subsequently rolled back
  rollbackReason  String?
  rollbackBy      String?     // Actor email who recorded the rollback
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([eventType])
  @@index([fromStage, toStage])
  @@index([researchRunId])
  @@index([approvedAt])
  @@map("foundry_promotions")
}

// ─── Intelligence Foundry — Feedback & Baselines ─────────────────────────────

/// Durable per-finding disposition from a human reviewer.
/// Authority over outputJson snapshot. Upserted per (runId, findingId) pair.
model FindingFeedback {
  id          String      @id @default(cuid())
  runId       String
  run         ResearchRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  findingId   String      // ID of the finding in findingsJson array
  engineId    String?     // Engine that emitted the finding
  moduleId    String?     // Foundry module (e.g. "market-response-lab")
  disposition String      // ACTED | DISMISSED | DEFERRED
  note        String?     // Optional freetext from reviewer
  updatedBy   String?     // Actor email

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([runId, findingId])
  @@index([runId])
  @@index([disposition])
  @@index([moduleId])
  @@index([engineId])
  @@map("finding_feedback")
}

/// Server-side performance baseline for a callable Foundry engine.
/// Complements local (localStorage) baselines with durable governance records.
/// Regressions against this baseline can block promotion to LIVE_GOVERNED.
model PerformanceBaseline {
  id          String   @id @default(cuid())
  engineId    String   @unique  // canonical engine ID (one durable baseline per engine)
  baselineMs  Float    // accepted avg execution time (ms)
  p95Ms       Float    // accepted p95 execution time (ms)
  sampleSize  Int      // number of iterations used to establish baseline
  environment String   @default("production") // production | staging | local
  notes       String?
  updatedBy   String?  // actor email
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([engineId])
  @@map("performance_baselines")
}

// ─── Privacy Architecture — Data Separation Layer ────────────────────────────

/// Stores decision data WITHOUT any PII. Identified only by opaque sessionId.
model DecisionSession {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  anchors     Json?
  pattern     String?
  trajectory  String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  link        SessionLink?

  @@index([sessionId])
  @@index([createdAt])
  @@map("decision_session")
}

/// Stores user identity with encrypted email. No decision data here.
model UserIdentity {
  id             String   @id @default(cuid())
  emailEncrypted String
  emailHash      String   @unique
  unsubscribed   Boolean  @default(false)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  links          SessionLink[]

  @@index([emailHash])
  @@map("user_identity")
}

/// Join table — the ONLY bridge between identity and decision data.
model SessionLink {
  id        String   @id @default(cuid())
  sessionId String   @unique
  userId    String
  createdAt DateTime @default(now())

  session   DecisionSession @relation(fields: [sessionId], references: [sessionId])
  user      UserIdentity    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@map("session_link")
}

// ============================================================================
// WEBHOOK IDEMPOTENCY
// ============================================================================

model ProcessedWebhookEvent {
  id        String   @id // Stripe event ID — guarantees exactly-once processing
  createdAt DateTime @default(now())

  @@map("processed_webhook_events")
}

// ============================================================================
// SOVEREIGN INTELLIGENCE LAYER
// ============================================================================

/// Anonymised diagnostic session record for the Intelligence Commons.
/// The sessionHash is a one-way SHA-256 of (orgId + sessionId).
/// This model contains NO PII — it cannot be used to re-identify any client.
model IntelligenceCommonsRecord {
  id               String   @id @default(cuid())
  sessionHash      String   @unique
  industryTag      String   @default("unspecified")
  revenueBand      String
  teamSizeBand     String   @default("SMALL")
  founderLed       Boolean  @default(false)
  sessionNumber    Int      @default(1)

  // Normalised scores (0–100)
  authorityClarity      Float
  narrativeCoherence    Float
  interventionReadiness Float
  executionReadiness    Float
  overallReadiness      Float  @default(50)

  overallPosture    String   // SOVEREIGN | ALIGNED | DRIFTING | MISALIGNED | DISORDERED
  trajectory        String   // IMPROVING | STABLE | DETERIORATING | COLLAPSING
  failureModeCount  Int      @default(0)

  // Active intelligence signal IDs (JSON array)
  activeSignalIds   Json     @default("[]")

  // Outcome data — populated on follow-up or admin input
  outcomeTag        String?
  outcomeTimeDays   Int?

  recordedAt        DateTime @default(now())

  @@index([revenueBand])
  @@index([industryTag])
  @@index([overallPosture])
  @@index([trajectory])
  @@index([recordedAt])
  @@map("intelligence_commons_record")
}

/// Institutional memory snapshot — one record per completed diagnostic session
/// for a given organisation handle (opaque, not PII).
model InstitutionalMemorySnapshot {
  id                    String   @id @default(cuid())
  organisationHandle    String
  sessionId             String
  sessionNumber         Int

  posture               String
  trajectory            String

  // Scores as individual columns for query efficiency
  authorityClarity      Float
  narrativeCoherence    Float
  interventionReadiness Float
  executionReadiness    Float
  overallReadiness      Float

  failureModeCount      Int      @default(0)
  activeSignalIds       Json     @default("[]")

  revenueBand           String?
  orgState              String?

  recordedAt            DateTime @default(now())

  @@index([organisationHandle])
  @@index([recordedAt])
  @@map("institutional_memory_snapshot")
}

/// Cohort assignment cache — avoids recomputing cohort on every session load.
model CohortAssignment {
  id                 String   @id @default(cuid())
  organisationHandle String   @unique
  cohortId           String
  matchStrength      String   // EXACT | CLOSE | APPROXIMATE
  assignedAt         DateTime @default(now())
  expiresAt          DateTime

  @@index([organisationHandle])
  @@index([cohortId])
  @@map("cohort_assignment")
}

// ============================================================================
// BENCHMARK AGGREGATE CACHE
// ============================================================================

/// Materialised benchmark aggregate — write-through cache updated by the
/// benchmark-context API route when stale (>1 hour). NOT the source of truth.
/// Source of truth: AuditEvent (objectType=OUTCOME_CONTRIBUTION, actionType=CONTRIBUTED).
///
/// key = assessmentKind value, or "__ALL__" for the global (unfiltered) aggregate.
/// One row per key. Upserted on each request that finds a stale or missing row.
model BenchmarkAggregate {
  id                        String   @id @default(cuid())
  /// assessmentKind value, or "__ALL__" for the global aggregate
  key                       String   @unique
  assessmentKind            String?
  n                         Int      @default(0)
  improved                  Int      @default(0)
  resolved                  Int      @default(0)
  unchanged                 Int      @default(0)
  worsened                  Int      @default(0)
  abandoned                 Int      @default(0)
  timeImmediate             Int      @default(0)
  timeShort                 Int      @default(0)
  timeMedium                Int      @default(0)
  timeLong                  Int      @default(0)
  timeDidNotAct             Int      @default(0)
  findingAccurateTotal      Int      @default(0)
  findingAccurateTrue       Int      @default(0)
  recommendationUsefulTotal Int      @default(0)
  recommendationUsefulTrue  Int      @default(0)
  computedAt                DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([assessmentKind])
  @@index([computedAt])
  @@map("benchmark_aggregates")
}

// ============================================================================
// INTEGRATION TOKENS — OAuth tokens for external integrations (LinkedIn, etc.)
// ============================================================================

/// Encrypted OAuth tokens for third-party integrations.
/// Tokens are encrypted at rest using AES-256-GCM via OAUTH_TOKEN_ENCRYPTION_KEY.
/// Plain tokens are never stored, logged, or exposed to the client.
model IntegrationToken {
  id                   String   @id @default(cuid())
  provider             String   // e.g. "linkedin"
  organisationId       String   // e.g. "115850136"
  accessTokenEncrypted String   // AES-256-GCM encrypted
  refreshTokenEncrypted String? // AES-256-GCM encrypted (if returned by provider)
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scopes               String   // space-separated scope list
  connectedBy          String?  // user ID who connected
  connectedAt          DateTime @default(now())
  lastUsedAt           DateTime @default(now())
  status               String   @default("active") // "active" | "expired" | "revoked" | "disconnected"
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([provider, organisationId], name: "integration_token_provider_org")
  @@index([provider])
  @@index([status])
  @@map("integration_tokens")
}

/// Encrypted LinkedIn publishing connection for governed outbound publishing.
/// Tokens are encrypted at rest using LINKEDIN_TOKEN_ENCRYPTION_KEY.
/// v1 supports text-only company-page publishing with member-profile fallback.
model LinkedInPublishingConnection {
  id                    String    @id @default(cuid())
  provider              String    @default("linkedin")
  profileKey            String    @default("legacy") // "legacy" | "community"
  ownerType             String    // "member" | "organization"
  ownerUrn              String?
  accountMemberId       String?
  displayName           String?
  ownerName             String?
  isDefaultPublishingTarget Boolean @default(false)
  requiredScope         String    @default("w_member_social")
  encryptedAccessToken  String
  encryptedRefreshToken String?
  expiresAt             DateTime?
  scope                 String
  status                String    @default("active") // "active" | "revoked" | "expired" | "invalid"
  lastValidationStatus  String    @default("unverified")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastVerifiedAt        DateTime?

  @@unique([provider, profileKey, ownerType], name: "linkedin_publishing_connection_provider_profile_owner_type")
  @@index([provider])
  @@index([profileKey])
  @@index([status])
  @@map("linkedin_publishing_connections")
}

/// Governed record of LinkedIn publish attempts. Contains safe metadata only.
model LinkedInPublishAttempt {
  id               String    @id @default(cuid())
  outboundSlug     String
  outboundTitle    String
  status           String    // "pending" | "succeeded" | "failed" | "blocked"
  linkedInPostUrn  String?
  linkedInUrl      String?
  errorCode        String?
  errorMessageSafe String?
  actorEmailHash   String?
  actorId          String?
  requestId        String
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([outboundSlug])
  @@index([status])
  @@index([requestId])
  @@map("linkedin_publish_attempts")
}

// ============================================================================
// OUTBOUND PUBLISH LEDGER — durable, idempotent publish record for all providers
// ============================================================================

/// Durable publish ledger for outbound publishing across all providers.
/// The idempotency key (provider + outboundItemId + scheduledFor) prevents
/// duplicate publishes. This is the source of truth for publish state.
/// File writeback (frontmatter status: posted) is secondary.
model OutboundPublishLedger {
  id                String   @id @default(cuid())
  provider          String   // "linkedin" | "facebook" | "x"
  outboundItemId    String   // stable ID from frontmatter or filename-derived
  campaign          String?  // campaign slug (LinkedIn) or null
  assetSlug         String   // slug of the published asset
  sourcePath        String?  // filesystem path to the source file
  scheduledFor      String?  // ISO date string from frontmatter

  // Actor info (safe — no raw tokens or secrets)
  actorId           String?
  actorEmail        String?  // raw email (only for admin audit trail)
  actorEmailHash    String?  // SHA-256 hash for privacy-safe queries

  // Status
  status            String   // IN_PROGRESS | DRY_RUN | PUBLISHED | FAILED | BLOCKED | SKIPPED

  // Provider response
  providerPostId    String?  // LinkedIn URN, tweet ID, Facebook post ID
  providerPostUrl   String?  // URL to the published post

  // Idempotency
  idempotencyKey    String   // unique: provider + outboundItemId + scheduledFor

  // Sync
  syncTargetsJson   String?  // JSON array of sync target provider IDs

  // Error handling
  errorCode         String?
  safeMessage       String?

  // Force republish tracking
  forceRepublish    Boolean  @default(false)
  forceRepublishActorId String?
  forceRepublishNote    String?

  // Source: who triggered this — "manual" | "scheduler"
  source            String   @default("manual")

  // Timestamps
  createdAt         DateTime @default(now())
  completedAt       DateTime?

  @@unique([idempotencyKey], name: "outbound_publish_ledger_idempotency")
  @@index([provider])
  @@index([outboundItemId])
  @@index([assetSlug])
  @@index([status])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@index([source])
  @@map("outbound_publish_ledger")
}

// ============================================================================
// SCHEDULER LOCK — prevents duplicate concurrent scheduler runs
// ============================================================================

/// Distributed lock for the outbound scheduler.
/// Only one scheduler run can hold the lock at a time.
/// Stale locks expire after lockTimeoutMs.
model SchedulerLock {
  id              String   @id @default(cuid())
  lockKey         String   @unique // e.g. "outbound-scheduler"
  lockedAt        DateTime @default(now())
  expiresAt       DateTime
  holder          String?  // hostname or PID that acquired the lock
  metadata        String?  // JSON with additional context

  @@index([lockKey])
  @@index([expiresAt])
  @@map("scheduler_locks")
}

/// Records of scheduler runs for operator visibility.
model SchedulerRun {
  id              String   @id @default(cuid())
  runKey          String   @unique // e.g. "sched_<timestamp>_<random>"
  source          String   // "api" | "cron" | "manual"
  dryRun          Boolean  @default(false)
  provider        String?  // null = all providers
  campaign        String?  // null = all campaigns
  status          String   // "started" | "completed" | "failed" | "skipped"
  scannedCount    Int      @default(0)
  eligibleCount   Int      @default(0)
  publishedCount  Int      @default(0)
  skippedCount    Int      @default(0)
  failedCount     Int      @default(0)
  summary         String?  // JSON summary of results
  errorMessage    String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([runKey])
  @@index([source])
  @@index([status])
  @@index([startedAt])
  @@map("scheduler_runs")
}

// ============================================================================
// OUTBOUND CONTROL STATE — runtime scheduler pause, DB-backed (no redeploy)
// ============================================================================

/// Single-row config table for runtime outbound scheduler controls.
/// Upserted by the pause/resume API (OWNER-only). Always one row (id = "singleton").
model OutboundControlState {
  id              String    @id @default("singleton")
  schedulerPaused Boolean   @default(false)
  pausedReason    String?
  pausedById      String?
  pausedByEmail   String?
  pausedAt        DateTime?
  resumedAt       DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@map("outbound_control_state")
}

// ============================================================================
// RATE LIMIT EVENTS — Postgres-authoritative, scope-keyed, identifier-hashed
// ============================================================================

/// Scoped rate-limit counter for governance endpoints.
/// Identifier is HMAC-hashed before storage; raw IP/email is never persisted.
/// Compound unique enforces one row per (scope, identifierHash, windowStart).
/// Cleanup job: DELETE WHERE windowStart < now() - interval '14 days'.
model RateLimitEvent {
  id             String   @id @default(cuid())
  scope          String
  identifierHash String
  windowStart    DateTime
  windowSeconds  Int
  count          Int      @default(1)
  limit          Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scope, identifierHash, windowStart, windowSeconds], name: "scope_identifier_window")
  @@index([windowStart], name: "rate_limit_event_cleanup_idx")
  @@map("rate_limit_events")
}

// ============================================================================
// TERMS ACCEPTANCE — versioned, first-authenticated-use tracking
// ============================================================================

/// Records which version of Terms and Privacy a user has accepted.
/// One row per (userId, docType). Upserted on each new acceptance.
/// docType: "TERMS" | "PRIVACY"
model TermsAcceptance {
  id          String   @id @default(cuid())
  userId      String
  email       String
  docType     String
  version     String
  acceptedAt  DateTime @default(now())
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, docType], name: "terms_acceptance_user_doc")
  @@index([userId])
  @@index([email])
  @@index([docType, version])
  @@map("terms_acceptances")
}

// ============================================================================
// STALE CASE NOTIFICATIONS — duplicate-send protection
// ============================================================================

/// Tracks sent stale-case alert emails per (caseId, band) window.
/// Prevents duplicate sends within the same notification period.
/// muted: user has requested no further alerts for this case.
/// extendedUntil: user has snoozed alerts until this date.
model StaleCaseNotification {
  id            String    @id @default(cuid())
  caseId        String
  userEmail     String
  band          String
  sentAt        DateTime  @default(now())
  returnLinkToken String?
  muted         Boolean   @default(false)
  extendedUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([caseId, userEmail, band], name: "stale_case_notification_window")
  @@index([caseId])
  @@index([userEmail])
  @@index([sentAt])
  @@map("stale_case_notifications")
}

// ============================================================================
// SECURITY ASSURANCE REQUESTS — controlled disclosure workflow
// ============================================================================

/// Tracks procurement/security team requests for controlled assurance materials.
/// Does not store document content. Status is updated manually by operator.
/// Allowed statuses: NEW | UNDER_REVIEW | PUBLIC_PACK_APPROVED | NDA_REQUIRED |
///   RESTRICTED_PACK_APPROVED | DECLINED | FULFILLED
model SecurityAssuranceRequest {
  id                String   @id @default(cuid())
  name              String?
  email             String
  organisation      String?
  role              String?
  requestedMaterial String
  procurementStage  String?
  message           String?
  status            String   @default("NEW")
  decisionNote      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
  @@index([requestedMaterial])
  @@index([status])
  @@index([createdAt])
  @@map("security_assurance_requests")
}


  @@index([decisionOutcomeRecordId])
  @@index([userEmail])
  @@index([patternObservationId])
  @@index([patternType])
  @@index([riskOfRepeat])
  @@index([createdAt])
  @@map("outcome_pattern_observations")
}

// ─────────────────────────────────────────────────────────────────────────────
// RETAINER READINESS EVALUATION
//
// Records the result of a retainer readiness evaluation for a given
// organisation or case cluster. Admin-reviewed before Retainer Oversight
// is offered.
// ─────────────────────────────────────────────────────────────────────────────

model RetainerReadinessEvaluation {
  id                      String    @id @default(cuid())
  organisationId          String?
  userEmail               String?
  // Readiness dimensions (0–1 score or boolean)
  durableMemoryPresent    Boolean   @default(false)
  recurringDecisionPattern Boolean  @default(false)
  outcomeHistoryPresent   Boolean   @default(false)
  repeatedHighRisk        Boolean   @default(false)
  evidenceQualityScore    Float     @default(0)           // 0–1
  organisationSignalScore Float     @default(0)           // 0–1
  // Overall
  overallReadinessScore   Float     @default(0)           // 0–1
  readinessClass          String    @default("NOT_READY") // NOT_READY | CANDIDATE | REVIEW_READY | APPROVED
  evaluatorNotes          String?
  adminApprovalRequired   Boolean   @default(true)
  adminApprovedAt         DateTime?
  adminApprovedBy         String?
  // Evidence basis
  evidenceSourceIds       Json      @default("[]")        // array of run/dossier/diagnostic IDs
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([organisationId])
  @@index([userEmail])
  @@index([readinessClass])
  @@index([createdAt])
  @@map("retainer_readiness_evaluations")
}


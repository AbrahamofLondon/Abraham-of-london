  @@unique([type, sessionId])
  @@index([createdAt])
}

// Secure, token-based access for client-facing boardroom dossier delivery.
// Replaces email-query-parameter access.
model BoardroomDossierAccessToken {
  id           String    @id @default(cuid())
  dossierId    String
  tokenHash    String    @unique   // SHA-256 of raw token — raw token never stored
  clientEmail  String?
  clientName   String?
  expiresAt    DateTime
  revokedAt    DateTime?
  lastViewedAt DateTime?
  viewCount    Int       @default(0)
  createdBy    String
  createdAt    DateTime  @default(now())

  dossier      BoardroomDossier @relation(fields: [dossierId], references: [id])

  @@index([dossierId])
  @@index([tokenHash])
  @@index([expiresAt])

  deliveryEvents BoardroomDeliveryEvent[]
}

// Event log for boardroom dossier delivery operations.
// Records GENERATED, SENT, VIEWED, EXPIRED, REVOKED, RESENT per token.
model BoardroomDeliveryEvent {
  id          String   @id @default(cuid())
  tokenId     String
  dossierId   String
  eventType   String   // GENERATED | SENT | VIEWED | EXPIRED | REVOKED | RESENT | SEND_FAILED
  clientEmail String?
  performedBy String?  // admin email for admin actions; null for automated/client events
  metadata    Json?    // extra context (error message, resend source token id, etc.)
  createdAt   DateTime @default(now())

  token       BoardroomDossierAccessToken @relation(fields: [tokenId], references: [id])

  @@index([tokenId])
  @@index([dossierId])
  @@index([eventType])
  @@index([createdAt])
}

// Client Portal: magic-link session for client access to their deliverables.
// Token: 32 random bytes, SHA-256 hash stored. Raw token never persisted.
model ClientPortalSession {
  id          String    @id @default(cuid())
  clientEmail String
  tokenHash   String    @unique
  expiresAt   DateTime

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// --- ENUMS ---

enum AlignmentBand {
  ALIGNED
  DRIFTING
  MISALIGNED
  DISORDERED
}

enum AlignmentDomain {
  IDENTITY
  DECISION
  ENVIRONMENT
  BEHAVIOUR
  EMOTIONAL_ORDER
  LEGACY
}

enum MemberRole {
  ADMIN
  STRATEGIST
  MEMBER
  CLIENT
}

enum MemberStatus {
  active
  inactive
  pending
  suspended
}

enum AccessTier {
  member
  client
  partner
  executive
  sovereign
}

enum ContentType {
  Briefs
  Dossier
  Operational_Framework
  Landing
  Leadership
  Audit
  Research
  Sovereign_Intelligence
  Lexicon
  Intelligence
  Prints
  Strategy
}

enum LinkType {
  DEPENDENCY
  RELATED
  PREREQUISITE
}

enum AnnotationPriority {
  ROUTINE
  URGENT
  CRITICAL
}

enum InquiryStatus {
  PENDING
  REVIEWING
  CONTACTED
  CLOSED
}

enum StrategyIntakeStatus {
  PENDING
  IN_REVIEW
  ANALYZED
  ARCHIVED
}

enum DownloadEventType {
  PREVIEW
  DOWNLOAD
  PRINT
}

enum DownloadDeliveryMode {
  DIRECT
  EMAIL
  SECURE_LINK
}

enum DownloadContentType {
  PDF
  EPUB
  MARKDOWN
  ASSET
}

enum AccessType {
  VIEW
  DOWNLOAD
  METADATA
}

enum AuditSeverity {
  debug
  info
  warn
  error
  critical
}

enum SecurityEvent {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  MFA_CHALLENGE
  PASSWORD_CHANGE
  UNAUTHORIZED_ACCESS
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum SessionStatus {
  active
  expired
  revoked
}

enum KeyStatus {
  active
  revoked
  expired
}

enum MfaMethod {
  totp
  sms
  email
}

enum Permission {
  READ_BRIEFS
  DOWNLOAD_REPORTS
  ACCESS_VAULT
  MANAGE_ORGS
  ADMIN_ACCESS
}

// --- ORGANISATION & ENTERPRISE CAMPAIGN SYSTEM ---

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sector    String?
  sizeBand  String?
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrganisationMembership[]
  campaigns   AlignmentCampaign[]

  @@index([name])
}

model OrganisationMembership {
  id             String   @id @default(cuid())
  organisationId String
  userId         String?
  email          String
  fullName       String?
  roleTitle      String?
  teamName       String?
  functionName   String?
  seniorityBand  String?
  isExecutive    Boolean  @default(false)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  createdCampaigns AlignmentCampaign[]   @relation("CampaignCreatedByMembership")
  participants     CampaignParticipant[]

  @@unique([organisationId, email])
  @@index([organisationId])
  @@index([email])
  @@index([teamName])
  @@index([status])
}

model AlignmentCampaign {
  id                    String    @id @default(cuid())
  organisationId        String
  title                 String
  objective             String?
  status                String    @default("draft")
  opensAt               DateTime?
  closesAt              DateTime?
  cadenceType           String    @default("ad_hoc")
  createdByMembershipId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organisation        Organisation            @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdByMembership OrganisationMembership? @relation("CampaignCreatedByMembership", fields: [createdByMembershipId], references: [id])

  participants           CampaignParticipant[]
  assessments            EnterpriseAssessment[]
  auditResponses         AuditResponse[]          // ANONYMOUS TELEMETRY LINK
  teamSnapshots          TeamAssessmentSnapshot[]
  organisationSnapshots  OrganisationAssessmentSnapshot[]
  leadershipGapSnapshots LeadershipGapSnapshot[]
  reports                EnterpriseReport[]

  @@index([organisationId])
  @@index([status])
  @@index([opensAt])
  @@index([closesAt])
}

model CampaignParticipant {
  id              String    @id @default(cuid())
  campaignId      String
  membershipId    String?
  email           String
  inviteTokenHash String
  status          String    @default("invited")
  invitedAt       DateTime  @default(now())
  openedAt        DateTime?
  completedAt     DateTime?
  reminderCount   Int       @default(0)

  campaign   AlignmentCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  membership OrganisationMembership? @relation(fields: [membershipId], references: [id])

  assessments EnterpriseAssessment[]

  @@unique([campaignId, email])
  @@index([campaignId])
  @@index([membershipId])
  @@index([email])
  @@index([status])
}

// THE SHREDDED TELEMETRY NODE
// Intentionally lacks userId or participantId for anonymity
model AuditResponse {
  id         String   @id @default(cuid())
  campaignId String
  resonance  Int      // Scale 1-10
  certainty  Int      // Scale 1-10
  createdAt  DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("audit_responses")
}

model EnterpriseAssessment {
  id                   String   @id @default(cuid())
  campaignId           String
  participantId        String
  organisationId       String
  teamName             String?
  isExecutive          Boolean  @default(false)
  answersJson          Json
  totalScore           Int
  possibleScore        Int
  percentScore         Int
  band                 String
  weakestDomainsJson   Json
  strongestDomainsJson Json?
  domainScoresJson     Json
  submittedAt          DateTime @default(now())

  campaign    AlignmentCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant CampaignParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
  @@index([participantId])
  @@index([teamName])
  @@index([isExecutive])
  @@index([submittedAt])
}

model TeamAssessmentSnapshot {
  id                   String   @id @default(cuid())
  campaignId           String
  organisationId       String
  teamName             String
  respondentCount      Int
  totalScore           Int
  possibleScore        Int
  percentScore         Int
  band                 String
  weakestDomainsJson   Json
  strongestDomainsJson Json
  domainScoresJson     Json
  varianceScoresJson   Json
  generatedAt          DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, teamName])
  @@index([campaignId])
  @@index([organisationId])
  @@index([teamName])
}

model OrganisationAssessmentSnapshot {
  id                   String   @id @default(cuid())
  campaignId           String
  organisationId       String
  respondentCount      Int
  invitedCount         Int
  completionRate       Int
  totalScore           Int
  possibleScore        Int
  percentScore         Int
  band                 String
  weakestDomainsJson   Json
  strongestDomainsJson Json
  domainScoresJson     Json
  varianceScoresJson   Json
  fragilitySignal      String?
  generatedAt          DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId])
  @@index([campaignId])
  @@index([organisationId])
}

model LeadershipGapSnapshot {
  id                      String   @id @default(cuid())
  campaignId              String
  organisationId          String
  overallGapPercent       Int
  domainGapsJson          Json
  interpretationFlagsJson Json
  generatedAt             DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId])
  @@index([campaignId])
  @@index([organisationId])
}

model EnterpriseReport {
  id             String   @id @default(cuid())
  campaignId     String
  organisationId String
  reportType     String
  filename       String
  storagePath    String?
  reportVersion  String
  generatedAt    DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
  @@index([reportType])
}

// --- CORE INDIVIDUAL ASSESSMENT MODELS ---

model PurposeAlignmentAssessment {
  id                 String                     @id @default(cuid())
  userId             String?
  sessionKey         String?
  title              String                     @default("Purpose Alignment Assessment")
  notes              String?                    @db.Text
  totalScore         Int
  possibleScore      Int
  percentScore       Int
  band               AlignmentBand
  
  fragilitySignal    String?                    @default("LOW")
  dissonanceArea     Int?                       @default(0)
  varianceScores     Json?                      
  
  weakestDomains     Json
  strengths          Json
  corrections        Json
  answers            Json
  domainScores       Json
  reportVersion      String                     @default("1.0.0")
  sourceInstrumentId String                     @default("IA-PAC-001")
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  reports      PurposeAlignmentReport[]
  reminderLogs PurposeAlignmentReminderLog[]

  @@index([userId, createdAt])
  @@index([sessionKey, createdAt])
}

model PurposeAlignmentReport {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    PurposeAlignmentAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  filename      String
  storagePath   String?
  generatedAt   DateTime @default(now())
  reportVersion String   @default("1.0.0")

  @@index([assessmentId, generatedAt])
}

model PurposeAlignmentReminderPreference {
  id           String    @id @default(cuid())
  userId       String?   @db.Uuid
  sessionKey   String?
  email        String?
  isEnabled    Boolean   @default(true)
  cadenceDays  Int       @default(30)
  lastSentAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user InnerCircleMember? @relation(fields: [userId], references: [id], onDelete: SetNull)
  logs PurposeAlignmentReminderLog[]

  @@unique([userId, sessionKey])
  @@index([userId])
  @@index([sessionKey])
  @@index([isEnabled])
  @@map("purpose_alignment_reminder_preferences")
}

model PurposeAlignmentReminderLog {
  id           String    @id @default(cuid())
  userId       String?   @db.Uuid
  sessionKey   String?
  email        String?
  assessmentId String
  status       String    @default("queued")
  channel      String    @default("in_app")
  scheduledFor DateTime
  sentAt       DateTime?
  payload      Json
  error        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assessment PurposeAlignmentAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       InnerCircleMember?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  preference PurposeAlignmentReminderPreference? @relation(fields: [preferenceId], references: [id], onDelete: SetNull)
  preferenceId String? @map("preference_id")

  @@index([userId])
  @@index([sessionKey])
  @@index([status])
  @@index([scheduledFor])
  @@index([assessmentId])
  @@index([preferenceId])
  @@map("purpose_alignment_reminder_logs")
}

// --- IDENTITY & ACCESS MODELS ---

model Organization {
  id        String               @id @default(cuid())
  slug      String               @unique
  name      String
  status    String               @default("active")
  metadata  Json?                @default("{}")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  invites   OrganizationInvite[]
  members   OrganizationMember[]

  @@index([slug])
  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id             String            @id @default(cuid())
  organizationId String
  role           MemberRole        @default(MEMBER)
  status         MemberStatus      @default(active)
  permissions    Permission[]      @default([])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  memberId       String            @db.Uuid
  member         InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, memberId])
  @@index([organizationId])
  @@index([memberId])
  @@map("organization_members")
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  tokenHash      String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  metadata       Json?        @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
  @@map("organization_invites")
}

model InnerCircleMember {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  email           String?              @unique @map("email")
  name            String?              @map("name")
  role            MemberRole           @default(MEMBER) @map("role")
  status          MemberStatus         @default(active) @map("status")
  tier            AccessTier           @default(member) @map("tier")
  flags           String?              @map("flags")
  metadata        Json?                @default("{}") @map("metadata")
  emailHash       String               @unique @map("email_hash")
  emailHashPrefix String?              @map("email_hash_prefix")
  passwordHash    String?              @map("password_hash")
  lastIp          String?              @map("last_ip")
  viewCount       Int                  @default(0) @map("view_count")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  lastSeenAt      DateTime             @default(now()) @map("last_seen_at")

  permissions     Permission[]         @default([]) @map("permissions")
  adminSessions   AdminSession[]
  apiKeys         ApiKey[]
  apiLogs         ApiLog[]
  downloadEvents  DownloadAuditEvent[] @relation("MemberDownloadEvents")
  frameworkAccess FrameworkAccessLog[]
  keys            InnerCircleKey[]
  MfaSetup        MfaSetup?
  orgMemberships  OrganizationMember[]
  pageViews       PageView[]
  premiumTokens   PremiumDownloadToken[]
  annotations     PrivateAnnotation[]
  rateLimitLogs   RateLimitLog[]
  securityLogs    SecurityLog[]
  sessions        Session[]
  inquiries       StrategyInquiry[]
  strategyIntakes StrategyIntake[]
  preferences     UserPreference?

  alignmentReminderPreferences PurposeAlignmentReminderPreference[]
  alignmentReminderLogs        PurposeAlignmentReminderLog[]

  @@index([status])
  @@index([tier])
  @@index([role])
  @@index([emailHash])
  @@index([lastSeenAt])
  @@map("inner_circle_members")
}

// --- CONTENT & KNOWLEDGE MODELS ---

model ContentMetadata {
  id               String               @id @default(cuid())
  slug             String               @unique
  title            String
  contentType      ContentType          @default(Briefs)
  summary          String?              @db.Text
  content          String?              @db.Text
  metadata         Json?                @default("{}")
  version          String               @default("1.0.0")
  
  embedding        Unsupported("vector")?

  totalPrints     Int                  @default(0)
  engagementScore  Float                @default(0.0)
  downloadCount    Int                  @default(0)
  viewCount        Int                  @default(0)
  fileSize         Int?
  pageCount        Int?
  pdfPath          String?

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  lastDownloadedAt DateTime?
  lastViewedAt     DateTime?

  classification   AccessTier           @default(client)

  canonEntries     CanonEntry[]
  sourceRelations  ContentRelation[]    @relation("SourceRelations")
  targetRelations  ContentRelation[]    @relation("TargetRelations")
  downloadEvents   DownloadAuditEvent[] @relation("ContentDownloadEvents")
  frameworkAccess  FrameworkAccessLog[] @relation("ContentFrameworkAccess")
  premiumTokens    PremiumDownloadToken[]
  annotations      PrivateAnnotation[]
  dependencies     StrategicLink[]      @relation("SourceBrief")
  dependents       StrategicLink[]      @relation("TargetBrief")

  @@index([slug])
  @@index([classification])
  @@index([contentType])
  @@map("content_metadata")
}

model Framework {
  id               String               @id @default(cuid())
  slug             String               @unique
  title            String
  description      String?
  oneLiner         String?
  tag              String?
  accent           String?
  canonRoot        String?
  audience         String[]
  tier             AccessTier           @default(member)
  pdfPath          String
  fileSize         Int?
  pageCount        Int?
  version          String               @default("1.0.0")
  content          String?
  artifactUrl      String?
  viewCount        Int                  @default(0)
  downloadCount    Int                  @default(0)
  lastViewedAt     DateTime?
  lastDownloadedAt DateTime?
  isActive         Boolean              @default(true)
  metadata         Json?                @default("{}")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  downloadEvents   DownloadAuditEvent[] @relation("FrameworkDownloadEvents")
  accessLogs       FrameworkAccessLog[] @relation("FrameworkAccess")

  @@index([slug])
  @@map("frameworks")
}

model StrategicLink {
  id          String          @id @default(cuid())
  sourceId    String
  targetId    String
  strength    Float           @default(1.0)
  linkType    LinkType        @default(DEPENDENCY)
  createdAt   DateTime        @default(now())
  sourceBrief ContentMetadata @relation("SourceBrief", fields: [sourceId], references: [id], onDelete: Cascade)
  targetBrief ContentMetadata @relation("TargetBrief", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("strategic_links")
}

model ContentRelation {
  id           String          @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String
  weight       Float           @default(1.0)
  createdAt    DateTime        @default(now())
  source       ContentMetadata @relation("SourceRelations", fields: [sourceId], references: [id], onDelete: Cascade)
  target       ContentMetadata @relation("TargetRelations", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@map("content_relations")
}

model PrivateAnnotation {
  id        String             @id @default(cuid())
  body      String
  priority  AnnotationPriority @default(ROUTINE)
  contentId String
  embedding Unsupported("vector")?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  memberId  String             @db.Uuid
  content   ContentMetadata    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  member    InnerCircleMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("private_annotations")
}

// --- AUDIT & SYSTEM LOGS ---

model DownloadAuditEvent {
  id                String               @id @default(cuid())
  slug              String
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime             @default(now())
  emailHash         String?
  ipHash            String?
  latencyMs         Int
  metadata          Json?                @default("{}")
  processedAt       DateTime
  success           Boolean
  memberId          String?              @db.Uuid
  errorCode         String?
  errorDetail       String?
  referrer          String?
  statusCode        Int?
  eventType         DownloadEventType    @default(PREVIEW)
  contentId         String?
  deliveredChecksum String?
  deliveryMode      DownloadDeliveryMode @default(DIRECT)
  email             String?
  fileHash          String?
  fileName          String?
  fileSize          BigInt?
  frameworkId       String?
  printAssetId      String?
  requestId         String?
  sessionId         String?
  sourceChecksum    String?
  title             String?
  watermarkId       String?
  contentType       DownloadContentType
  content           ContentMetadata?     @relation("ContentDownloadEvents", fields: [contentId], references: [id])
  framework         Framework?           @relation("FrameworkDownloadEvents", fields: [frameworkId], references: [id])
  member            InnerCircleMember?   @relation("MemberDownloadEvents", fields: [memberId], references: [id])
  printAsset        PrintAsset?          @relation("PrintDownloadEvents", fields: [printAssetId], references: [id])

  @@index([slug])
  @@index([createdAt])
  @@map("download_audit_events")
}

model FrameworkAccessLog {
  id           String             @id @default(cuid())
  slug         String
  memberId     String?            @db.Uuid
  accessType   AccessType         @default(VIEW)
  decision     Json
  allowed      Boolean
  requiredTier AccessTier?
  currentTier  AccessTier?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime           @default(now())
  contentId    String?
  frameworkId  String?
  requestId    String?
  sessionId    String?
  content      ContentMetadata?   @relation("ContentFrameworkAccess", fields: [contentId], references: [id])
  framework    Framework?         @relation("FrameworkAccess", fields: [frameworkId], references: [id])
  member       InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([slug])
  @@map("framework_access_logs")
}

model RateLimitLog {
  id        String             @id @default(cuid())
  key       String
  memberId  String?            @db.Uuid
  endpoint  String
  method    String?
  allowed   Boolean
  remaining Int
  limit     Int
  resetAt   DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())
  bucket    String?
  requestId String?
  sessionId String?
  member    InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([key])
  @@map("rate_limit_logs")
}

model SystemAuditLog {
  id           String        @id @default(cuid())
  action       String
  severity     AuditSeverity @default(info)
  actorId      String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?         @default("{}")
  createdAt    DateTime      @default(now())
  actorEmail   String?
  actorType    String?       @default("system") @map("actor_type") @db.VarChar(32)
  category     String?       @map("category") @db.VarChar(64)
  durationMs   Int?          @map("duration_ms")
  errorMessage String?       @map("error_message")
  requestId    String?       @map("request_id") @db.VarChar(128)
  resourceName String?       @map("resource_name") @db.VarChar(256)
  resourceType String?       @map("resource_type") @db.VarChar(64)
  sessionId    String?       @map("session_id") @db.VarChar(128)
  status       String?       @default("success") @map("status") @db.VarChar(16)
  subCategory  String?       @map("sub_category") @db.VarChar(128)
  tags         Json?         @default("[]") @map("tags")

  @@index([action])
  @@map("system_audit_logs")
}

model SecurityLog {
  id        String             @id @default(cuid())
  event     SecurityEvent
  severity  AuditSeverity      @default(info)
  action    String
  details   Json?              @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())
  memberId  String?            @db.Uuid
  member    InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([createdAt])
  @@map("security_logs")
}

model ApiLog {
  id             String             @id @default(cuid())
  endpoint       String
  method         HttpMethod
  statusCode     Int
  responseTimeMs Int                @default(0)
  ipAddress      String?
  userAgent      String?
  actorId        String?
  actorEmail     String?
  metadata       Json?              @default("{}")
  createdAt      DateTime           @default(now())
  memberId       String?            @db.Uuid
  member         InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([createdAt])
  @@map("api_logs")
}

// --- SESSION & SECURITY ---

model Session {
  id        String             @id @default(cuid())
  sessionId String             @unique
  status    SessionStatus      @default(active)
  expiresAt DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  memberId  String?            @db.Uuid
  ipAddress String?            @map("ip_address")
  metadata  Json?              @default("{}")
  userAgent String?            @map("user_agent")
  member    InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@map("sessions")
}

model InnerCircleKey {
  id            String            @id @default(cuid())
  keyHash       String            @unique
  status        KeyStatus         @default(active)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  expiresAt     DateTime
  keySuffix     String?           @db.VarChar(8)
  keyType       String
  lastUsedAt    DateTime?
  metadata      Json?             @default("{}")
  revokedAt     DateTime?
  revokedReason String?
  memberId      String            @db.Uuid
  member        InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("inner_circle_keys")
}

model MfaSetup {
  id            String            @id @default(cuid())
  enabled       Boolean           @default(false)
  methods       MfaMethod[]       @default([totp])
  totpSecret    String?
  totpVerified  Boolean           @default(false)
  backupCodes   Json?             @default("[]")
  phoneNumber   String?
  phoneVerified Boolean           @default(false)
  emailVerified Boolean           @default(false)
  recoveryEmail String?
  lastUsedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  userId        String            @unique @db.Uuid
  member        InnerCircleMember @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_setups")
}

// --- ASSETS & DOWNLOAD TOKENS ---

model PrintAsset {
  id          String               @id @default(cuid())
  slug        String               @unique
  title       String
  description String?
  filePath    String
  fileSize    Int?
  fileFormat  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tier        AccessTier           @default(member)
  downloads   DownloadAuditEvent[] @relation("PrintDownloadEvents")

  @@index([slug])
  @@map("print_assets")
}

model PremiumDownloadToken {
  id           String                   @id @default(cuid())
  tokenId      String                   @unique
  contentId    String
  userId       String?                  @db.Uuid
  sessionId    String?
  tier         String?
  issuedAt     DateTime                 @default(now())
  expiresAt    DateTime
  maxDownloads Int                      @default(1)
  usedCount    Int                      @default(0)
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  metadata     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  attempts     PremiumDownloadAttempt[]
  content      ContentMetadata          @relation(fields: [contentId], references: [slug], onDelete: Cascade)
  user         InnerCircleMember?       @relation(fields: [userId], references: [id])

  @@index([tokenId])
  @@map("premium_download_tokens")
}

model PremiumDownloadAttempt {
  id                 String                @id @default(cuid())
  tokenId            String?
  contentId          String
  userId             String?
  sessionId          String?
  ipAddress          String?
  ipHash             String?
  userAgent          String?
  referrer           String?
  method             String?
  success            Boolean
  statusCode         Int
  reason             String?
  watermarkId        String?
  sourceChecksum     String?
  deliveredChecksum  String?
  createdAt          DateTime              @default(now())
  downloadDuration   Int?
  fileSize           Int?
  pageCount          Int?
  requiredTier       String?
  userTier           String?
  requestFingerprint String?
  token              PremiumDownloadToken? @relation(fields: [tokenId], references: [tokenId])

  @@index([createdAt])
  @@map("premium_download_attempts")
}

// --- SUPPORTING INFRASTRUCTURE ---

model CanonEntry {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String?
  contentType String
  readTime    Int?
  metadataId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tier        AccessTier       @default(member)
  metadata    ContentMetadata? @relation(fields: [metadataId], references: [id])

  @@map("canon_entries")
}

model StrategicFramework {
  id          String     @id @default(cuid())
  key         String     @unique
  slug        String     @unique
  title       String
  oneLiner    String
  tag         String
  accent      String
  canonRoot   String
  audience    String[]
  content     String?
  artifactUrl String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tier        AccessTier @default(member)

  @@index([slug])
  @@map("strategic_frameworks")
}

model StrategyInquiry {
  id        String             @id @default(cuid())
  name      String
  email     String
  intent    String
  status    InquiryStatus      @default(PENDING)
  metadata  Json?              @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  memberId  String?            @db.Uuid
  member    InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([email])
  @@map("strategy_inquiries")
}

model StrategyIntake {
  id              String               @id @default(cuid())
  fullName        String
  organisation    String
  dependencyLevel String
  volatility      String
  readinessScore  Int                  @default(5)
  payload         Json
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  emailHash       String?
  memberId        String?              @db.Uuid
  analysisNotes   Json?                @default("{}")
  analysisVersion String?
  analyzedAt      DateTime?
  analyzedBy      String?
  score           Int?
  status          StrategyIntakeStatus @default(PENDING)
  member          InnerCircleMember?   @relation(fields: [memberId], references: [id])

  @@index([organisation])
  @@map("strategy_intakes")
}

model ApiKey {
  id        String             @id @default(cuid())
  name      String
  keyHash   String             @unique
  memberId  String             @db.Uuid
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  member    InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("api_keys")
}

model PageView {
  id        String             @id @default(cuid())
  path      String
  memberId  String?            @db.Uuid
  createdAt DateTime           @default(now())
  member    InnerCircleMember? @relation(fields: [memberId], references: [id])

  @@index([path])
  @@index([memberId])
  @@map("page_views")
}

model AdminSession {
  id        String            @id @default(cuid())
  memberId  String            @db.Uuid
  token     String            @unique
  createdAt DateTime          @default(now())
  expiresAt DateTime
  member    InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("admin_sessions")
}

model UserPreference {
  id        String            @id @default(cuid())
  memberId  String            @unique @db.Uuid
  settings  Json              @default("{}")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  member    InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
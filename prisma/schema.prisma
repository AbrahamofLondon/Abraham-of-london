datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// ============================================================================
// ENUMS
// ============================================================================

enum AlignmentBand {
  ALIGNED
  DRIFTING
  MISALIGNED
  DISORDERED
}

enum AlignmentDomain {
  IDENTITY
  DECISION
  ENVIRONMENT
  BEHAVIOUR
  EMOTIONAL_ORDER
  LEGACY
}

enum CorrectionStatus {
  MANDATED
  IN_PROGRESS
  LIQUIDATED
  ARCHIVED
}

enum MemberRole {
  ADMIN
  STRATEGIST
  MEMBER
  CLIENT
}

enum AccessTier {
  public
  member
  inner_circle
  restricted
  client
  legacy
  architect
  owner
  top_secret
}

enum MemberStatus {
  active
  inactive
  pending
  paused
  suspended
}

enum ContentType {
  Briefs
  Dossier
  Operational_Framework
  Landing
  Leadership
  Audit
  Research
  Sovereign_Intelligence
  Lexicon
  Intelligence
  Prints
  Strategy
}

enum LinkType {
  DEPENDENCY
  RELATED
  PREREQUISITE
}

enum AnnotationPriority {
  ROUTINE
  URGENT
  CRITICAL
}

enum InquiryStatus {
  PENDING
  REVIEWING
  CONTACTED
  CLOSED
}

enum StrategyIntakeStatus {
  PENDING
  IN_REVIEW
  ANALYZED
  ARCHIVED
}

enum DownloadEventType {
  PREVIEW
  DOWNLOAD
  PRINT
}

enum DownloadDeliveryMode {
  DIRECT
  EMAIL
  SECURE_LINK
}

enum DownloadContentType {
  PDF
  EPUB
  MARKDOWN
  ASSET
}

enum AccessType {
  VIEW
  DOWNLOAD
  METADATA
}

enum AuditSeverity {
  debug
  info
  warn
  error
  critical
}

enum SecurityEvent {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  MFA_CHALLENGE
  PASSWORD_CHANGE
  UNAUTHORIZED_ACCESS
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum SessionStatus {
  active
  expired
  revoked
}

enum KeyStatus {
  active
  revoked
  expired
}

enum MfaMethod {
  totp
  sms
  email
}

enum Permission {
  READ_BRIEFS
  DOWNLOAD_REPORTS
  ACCESS_VAULT
  MANAGE_ORGS
  ADMIN_ACCESS
}

enum DiagnosticSeverity {
  low
  moderate
  high
  critical
}

enum DiagnosticLifecycleStatus {
  draft
  completed
  archived
}

enum DiagnosticReportStatus {
  none
  pending
  paid
  generated
  failed
  revoked
}

enum DiagnosticArtifactKind {
  pdf
}

enum DiagnosticStorageProvider {
  local
  s3
}

enum DiagnosticRegenerationStatus {
  queued
  processing
  completed
  failed
  cancelled
}

enum GovernanceSeverity {
  CRITICAL
  HIGH
  WARNING
  INFO
  DEBUG
}

enum GovernanceStatus {
  ACTIVE
  PENDING
  RESOLVED
  SUPPRESSED
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum EntitlementType {
  TIER
  PRODUCT
  ARTIFACT
}

enum EntitlementStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AccessKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
  DEPLETED
}

enum InviteStatus {
  PENDING
  REDEEMED
  EXPIRED
  REVOKED
}

enum AuditActorType {
  USER
  SYSTEM
  ADMIN
}

// ============================================================================
// ORGANISATION & ENTERPRISE CAMPAIGN SYSTEM
// ============================================================================

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sector    String?
  sizeBand  String?
  region    String?
  status    String   @default("active")
  metadata  String?  @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   OrganisationMembership[]
  campaigns     AlignmentCampaign[]
  invites       OrganisationInvite[]
  interventions StrategicIntervention[]
  snapshots     AlignmentSnapshot[]

  @@index([name])
  @@index([status])
  @@index([slug])
}

model AlignmentCampaign {
  id                    String    @id @default(cuid())
  organisationId        String
  title                 String
  objective             String?
  status                String    @default("draft")
  opensAt               DateTime?
  closesAt              DateTime?
  cadenceType           String    @default("ad_hoc")
  createdByMembershipId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  metadata              String?   @default("{}")

  organisation        Organisation            @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdByMembership OrganisationMembership? @relation("CampaignCreatedByMembership", fields: [createdByMembershipId], references: [id])

  correctionNodes        CorrectionNode[]
  participants           CampaignParticipant[]
  assessments            EnterpriseAssessment[]
  auditResponses         AuditResponse[]
  teamSnapshots          TeamAssessmentSnapshot[]
  organisationSnapshots  OrganisationAssessmentSnapshot[]
  constitutionalIntakes  ConstitutionalIntakeReport[]
  executiveRuns          ExecutiveReportingRun[]
  leadershipGapSnapshots LeadershipGapSnapshot[]
  reports                EnterpriseReport[]
  interventions          StrategicIntervention[]
  snapshot               AlignmentSnapshot?               @relation("CampaignAlignmentSnapshot")

  @@index([organisationId])
  @@index([status])
  @@index([opensAt])
  @@index([closesAt])
}

model AlignmentSnapshot {
  id             String   @id @default(cuid())
  campaignId     String   @unique
  organisationId String
  cohortSize     Int
  aggregatedData String
  finalizedAt    DateTime @default(now())

  campaign     AlignmentCampaign @relation("CampaignAlignmentSnapshot", fields: [campaignId], references: [id], onDelete: Cascade)
  organisation Organisation      @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
  @@index([finalizedAt])
}

model OrganisationInvite {
  id             String       @id @default(cuid())
  organisationId String
  email          String
  tokenHash      String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  metadata       String?      @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([email])
  @@index([expiresAt])
  @@index([tokenHash])
  @@map("organisation_invites")
}

model OrganisationMembership {
  id             String   @id @default(cuid())
  organisationId String
  userId         String?
  email          String
  fullName       String?
  roleTitle      String?
  teamName       String?
  functionName   String?
  seniorityBand  String?
  isExecutive    Boolean  @default(false)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  createdCampaigns AlignmentCampaign[]   @relation("CampaignCreatedByMembership")
  participants     CampaignParticipant[]

  @@unique([organisationId, email])
  @@index([organisationId])
  @@index([email])
  @@index([teamName])
  @@index([status])
}

model GovernanceLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  target      String?
  details     String?
  createdAt   DateTime @default(now())
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          UserRole       @default(USER)

  accounts      UserAccount[]

  entitlements  Entitlement[]
  accessKeyUses AccessKeyUse[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([role])
}

model UserAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_accounts")
}

model Entitlement {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        EntitlementType
  key         String
  status      EntitlementStatus  @default(ACTIVE)

  metadata    Json?

  issuedAt    DateTime           @default(now())
  startsAt    DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  issuedBy    String?
  revokedBy   String?
  reason      String?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId, type, status])
  @@index([key, type, status])
  @@unique([userId, type, key, status], map: "entitlement_active_uniqueness")
}

model AccessKey {
  id            String           @id @default(cuid())
  codeHash       String           @unique
  codePreview    String
  label          String?
  status         AccessKeyStatus  @default(ACTIVE)

  grants         Json
  metadata       Json?

  maxUses        Int              @default(1)
  uses           Int              @default(0)

  startsAt       DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  issuedBy       String?
  revokedBy      String?
  reason         String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  usesLog        AccessKeyUse[]

  @@index([status])
  @@index([expiresAt])
}

model AccessKeyUse {
  id           String     @id @default(cuid())
  accessKeyId  String
  accessKey    AccessKey  @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  redeemedAt   DateTime   @default(now())
  ipAddress    String?
  userAgent    String?

  @@index([accessKeyId])
  @@index([userId])
  @@unique([accessKeyId, userId])
}

model AccessAuditLog {
  id            String         @id @default(cuid())
  actorType     AuditActorType
  actorUserId   String?
  actorEmail    String?

  action        String
  targetType    String
  targetKey     String?

  success       Boolean        @default(true)
  reason        String?
  metadata      Json?

  createdAt     DateTime       @default(now())

  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetKey])
}

model AccessInvite {
  id               String       @id @default(cuid())
  recipientEmail   String
  tokenHash        String       @unique
  grants           Json         // Array<{type, key}>
  status           InviteStatus @default(PENDING)

  issuedBy         String?
  issuedAt         DateTime     @default(now())
  expiresAt        DateTime?

  redeemedByUserId String?
  redeemedAt       DateTime?

  revokedAt        DateTime?
  revokedBy        String?
  reason           String?

  maxUses          Int          @default(1)
  uses             Int          @default(0)
  metadata         Json?

  emailSentAt      DateTime?
  emailError       String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([recipientEmail])
  @@index([status])
  @@index([expiresAt])
  @@map("access_invites")
}

model CampaignParticipant {
  id              String    @id @default(cuid())
  campaignId      String
  membershipId    String?
  email           String
  inviteTokenHash String
  status          String    @default("invited")
  invitedAt       DateTime  @default(now())
  openedAt        DateTime?
  completedAt     DateTime?
  reminderCount   Int       @default(0)

  campaign   AlignmentCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  membership OrganisationMembership? @relation(fields: [membershipId], references: [id])

  assessments EnterpriseAssessment[]

  @@unique([campaignId, email])
  @@index([campaignId])
  @@index([membershipId])
  @@index([email])
  @@index([status])
}

model AuditResponse {
  id         String   @id @default(cuid())
  campaignId String
  resonance  Int
  certainty  Int
  createdAt  DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("audit_responses")
}

model EnterpriseAssessment {
  id                   String   @id @default(cuid())
  campaignId           String
  participantId        String
  organisationId       String
  teamName             String?
  isExecutive          Boolean  @default(false)
  answersJson          String
  totalScore           Int
  possibleScore        Int
  percentScore         Int
  band                 String
  weakestDomainsJson   String
  strongestDomainsJson String?
  domainScoresJson     String
  submittedAt          DateTime @default(now())

  campaign    AlignmentCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant CampaignParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
  @@index([participantId])
  @@index([teamName])
  @@index([isExecutive])
  @@index([submittedAt])
}

model TeamAssessmentSnapshot {
  id                   String   @id @default(cuid())
  campaignId           String
  organisationId       String
  teamName             String
  respondentCount      Int
  totalScore           Int
  possibleScore        Int
  percentScore         Int
  band                 String
  weakestDomainsJson   String
  strongestDomainsJson String
  domainScoresJson     String
  varianceScoresJson   String
  generatedAt          DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, teamName])
  @@index([campaignId])
  @@index([organisationId])
  @@index([teamName])
}

model TeamAssessmentCampaign {
  id                       String   @id @default(cuid())
  organisationId           String?
  sponsorUserId            String?
  slug                     String?  @unique
  title                    String
  mode                     String   @default("leader_estimate")
  status                   String   @default("draft")
  closesAt                 DateTime?
  minimumResponseThreshold Int      @default(3)
  anonymityMode            String   @default("anonymous")
  domainsJson              String
  leaderEstimateJson       String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  invites   TeamAssessmentInvite[]
  responses TeamAssessmentResponse[]
  aggregate TeamAssessmentAggregate?

  @@index([organisationId])
  @@index([sponsorUserId])
  @@index([mode])
  @@index([status])
  @@index([closesAt])
}

model TeamAssessmentInvite {
  id          String    @id @default(cuid())
  campaignId  String
  tokenHash   String    @unique
  email       String?
  roleLabel   String?
  status      String    @default("issued")
  issuedAt    DateTime  @default(now())
  openedAt    DateTime?
  submittedAt DateTime?
  expiresAt   DateTime?

  campaign TeamAssessmentCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  response TeamAssessmentResponse?

  @@index([campaignId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

model TeamAssessmentResponse {
  id            String   @id @default(cuid())
  campaignId    String
  inviteId      String?  @unique
  respondentKey String
  answersJson   String
  submittedAt   DateTime @default(now())

  campaign TeamAssessmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invite   TeamAssessmentInvite?  @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([respondentKey])
  @@index([submittedAt])
}

model TeamAssessmentAggregate {
  id             String   @id @default(cuid())
  campaignId     String   @unique
  respondentCount Int
  invitedCount    Int
  completionRate  Float
  confidence      Float
  claimLevel      String
  domainsJson     String
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign TeamAssessmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([claimLevel])
  @@index([generatedAt])
}

model OrganisationAssessmentSnapshot {
  id                   String   @id @default(cuid())
  campaignId           String   @unique
  organisationId       String
  respondentCount      Int
  invitedCount         Int
  completionRate       Int
  totalScore           Int
  possibleScore        Int
  percentScore         Int
  band                 String
  weakestDomainsJson   String
  strongestDomainsJson String
  domainScoresJson     String
  varianceScoresJson   String
  fragilitySignal      String?
  generatedAt          DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
}

model LeadershipGapSnapshot {
  id                      String   @id @default(cuid())
  campaignId              String   @unique
  organisationId          String
  overallGapPercent       Int
  domainGapsJson          String
  interpretationFlagsJson String
  generatedAt             DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
}

model EnterpriseReport {
  id             String   @id @default(cuid())
  campaignId     String
  organisationId String
  reportType     String
  filename       String
  storagePath    String?
  reportVersion  String
  generatedAt    DateTime @default(now())

  campaign AlignmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([organisationId])
  @@index([reportType])
}

// ============================================================================
// DIAGNOSTIC ARTEFACT REGISTRY / LINEAGE / RETENTION
// ============================================================================

model DiagnosticRecord {
  id             String             @id @default(cuid())
  diagnosticType String
  title          String?
  score          Int
  severity       DiagnosticSeverity
  verdict        String
  responsesJson  String
  notes          String?

  userEmail String?
  userId    String?

  status       DiagnosticLifecycleStatus @default(completed)
  reportStatus DiagnosticReportStatus    @default(none)
  reportTier   String?

  latestVersion String?
  generatedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportOrders  DiagnosticReportOrder[]
  artifacts     DiagnosticArtifact[]
  accessGrants  DiagnosticArtifactAccessGrant[]
  lineageEvents DiagnosticLineageEvent[]
  auditEvents   DiagnosticAuditEvent[]
  regenJobs     DiagnosticRegenerationJob[]

  @@index([userEmail, createdAt])
  @@index([userId, createdAt])
  @@index([diagnosticType, createdAt])
  @@index([reportStatus, createdAt])
  @@index([status, createdAt])
  @@map("diagnostic_records")
}

model DiagnosticReportOrder {
  id                 String @id @default(cuid())
  diagnosticRecordId String

  stripeSessionId String? @unique
  stripePaymentId String?

  reportTier String
  amount     Int
  currency   String @default("gbp")
  status     String @default("pending")

  userEmail String?
  userId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  diagnosticRecord DiagnosticRecord @relation(fields: [diagnosticRecordId], references: [id], onDelete: Cascade)

  @@index([diagnosticRecordId])
  @@index([status, createdAt])
  @@map("diagnostic_report_orders")
}

model DiagnosticArtifact {
  id            String                 @id @default(cuid())
  diagnosticRef String
  diagnosticId  String
  reportId      String?
  version       String
  kind          DiagnosticArtifactKind @default(pdf)

  fileName   String
  mimeType   String
  byteLength Int
  sha256     String

  storageProvider DiagnosticStorageProvider
  objectKey       String
  bucket          String?

  etag       String?
  publicPath String?

  isRevoked     Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String?

  retentionClass String    @default("standard")
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  createdBy String?

  diagnostic DiagnosticRecord @relation(fields: [diagnosticId], references: [id], onDelete: Cascade)

  @@unique([diagnosticRef, version, kind])
  @@index([diagnosticRef])
  @@index([diagnosticId])
  @@index([version])
  @@index([isRevoked])
  @@map("diagnostic_artifacts")
}

model DiagnosticRegenerationJob {
  id            String  @id @default(cuid())
  diagnosticRef String
  diagnosticId  String?
  version       String?

  status  DiagnosticRegenerationStatus @default(queued)
  attempt Int                          @default(0)
  error   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  diagnostic DiagnosticRecord? @relation(fields: [diagnosticId], references: [id], onDelete: SetNull)

  @@index([diagnosticRef])
  @@index([diagnosticId])
  @@index([status, createdAt])
  @@map("diagnostic_regeneration_jobs")
}

model DiagnosticAuditEvent {
  id            String   @id @default(cuid())
  diagnosticRef String?
  diagnosticId  String?
  action        String
  actor         String?
  metadata      String?
  createdAt     DateTime @default(now())

  diagnostic DiagnosticRecord? @relation(fields: [diagnosticId], references: [id], onDelete: SetNull)

  @@index([diagnosticRef])
  @@index([diagnosticId])
  @@index([createdAt])
  @@map("diagnostic_audit_events")
}

model DiagnosticArtifactAccessGrant {
  id             String    @id @default(cuid())
  diagnosticRef  String
  diagnosticId   String
  artifactId     String
  granteeEmail   String
  entitlementKey String    @unique
  status         String    @default("active")
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  createdBy      String?

  diagnostic DiagnosticRecord @relation(fields: [diagnosticId], references: [id], onDelete: Cascade)

  @@index([diagnosticRef])
  @@index([diagnosticId])
  @@index([granteeEmail])
  @@index([diagnosticRef, granteeEmail])
  @@map("diagnostic_artifact_access_grants")
}

model DiagnosticLineageEvent {
  id               String   @id @default(cuid())
  diagnosticRef    String
  diagnosticId     String
  artifactId       String?
  parentArtifactId String?
  eventType        String
  version          String?
  actor            String?
  metadata         String?
  createdAt        DateTime @default(now())

  diagnostic DiagnosticRecord @relation(fields: [diagnosticId], references: [id], onDelete: Cascade)

  @@index([diagnosticRef])
  @@index([diagnosticId])
  @@index([createdAt])
  @@map("diagnostic_lineage_events")
}

model ProofEvidence {
  id                String   @id @default(cuid())
  sourceStage       String
  proofType         String
  routeResultType   String?
  accuracyScore     String?
  usefulnessScore   String?
  nextStepChanged   Boolean?
  actionIntent      String?
  outcomeCategory   String?
  mostAccuratePart  String?
  paidSpecificity   String?
  consequenceClear  Boolean?
  justifiedAction   Boolean?
  decisionClarity   String?
  nextMoveClear     Boolean?
  freeTextRaw       String?
  anonymisedSummary String?
  displayLabel      String?
  userType          String?
  organisationType  String?
  sourceOrigin      String?
  isPaidStage       Boolean  @default(false)
  followupAt        DateTime?
  approvalStatus    String   @default("PENDING")
  displayStatus     String   @default("HIDDEN")
  sourceKind        String   @default("SELF_REPORTED")
  adminNotes        String?
  metadataJson      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([sourceStage, createdAt])
  @@index([proofType, createdAt])
  @@index([approvalStatus, displayStatus])
  @@index([followupAt])
  @@map("proof_evidence")
}

model ClientEntitlement {
  id          String    @id @default(cuid())
  email       String
  productCode String
  tier        String
  status      String    @default("active")
  source      String    @default("manual")
  externalRef String?
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([productCode])
  @@index([email, productCode, status])
}

model BillingCustomer {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OperationalIncident {
  id          String    @id @default(cuid())
  title       String
  severity    String
  status      String    @default("open")
  category    String?
  summary     String?
  details     String?
  source      String?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  resolvedAt  DateTime?
  owner       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, severity])
  @@index([firstSeenAt])
}

model ArtifactManifest {
  id             String    @id @default(cuid())
  artifactId     String
  subjectEmail   String
  artifactType   String
  version        String?

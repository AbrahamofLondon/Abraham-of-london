// ============================================================================
// OPERATION 10/10 — CASE STUDY AND INTERNAL DECISION REGISTRY FOUNDATION
// ============================================================================

model CaseStudy {
  id                    String   @id @default(cuid())
  slug                  String?  @unique
  title                 String
  status                String   @default("DRAFT") // DRAFT | REVIEW | APPROVED | PUBLISHED | REJECTED | REVOKED
  publicationAllowed    Boolean  @default(false)
  anonymised            Boolean  @default(true)
  anonymisationNotes    String?
  sector                String?
  companySizeBand       String?
  region                String?
  sourceOutcomeRecordId String?
  returnBriefId         String?
  adminVerifiedRecordId String?
  verificationStatus    String   @default("UNVERIFIED") // UNVERIFIED | VERIFIED | DISPUTED
  consentStatus         String   @default("PENDING") // PENDING | GRANTED | REVOKED | NOT_REQUIRED
  narrative             Json     @default("{}")
  publicPayload         Json?
  reviewedBy            String?
  reviewedAt            DateTime?
  publishedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  evidence              CaseStudyEvidence[]
  consents              CaseStudyConsent[]
  outcomes              CaseStudyOutcome[]

  @@index([status])
  @@index([publicationAllowed])
  @@index([verificationStatus])
  @@index([consentStatus])
  @@index([sourceOutcomeRecordId])
  @@index([returnBriefId])
  @@index([sector])
  @@index([companySizeBand])
  @@map("case_studies")
}

model CaseStudyEvidence {
  id                 String   @id @default(cuid())
  caseStudyId        String
  sourceType         String
  sourceId           String
  evidenceHash       String?
  verificationStatus String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  notes              String?
  createdAt          DateTime @default(now())

  caseStudy          CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@index([caseStudyId])
  @@index([sourceType, sourceId])
  @@index([verificationStatus])
  @@map("case_study_evidence")
}

model CaseStudyConsent {
  id                String    @id @default(cuid())
  caseStudyId       String
  consentStatus     String    @default("PENDING") // PENDING | GRANTED | REVOKED
  grantedByEmail    String?
  scope             String    @default("ANONYMISED_PUBLICATION")
  anonymisedAllowed Boolean   @default(true)
  publicUseAllowed  Boolean   @default(false)
  grantedAt         DateTime?
  revokedAt         DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  caseStudy         CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@index([caseStudyId])
  @@index([consentStatus])
  @@index([grantedByEmail])
  @@map("case_study_consents")
}

model CaseStudyOutcome {
  id                      String   @id @default(cuid())
  caseStudyId             String
  decisionOutcomeRecordId String?
  outcomeClass            String
  outcomeSummary          String
  verifiedBy              String?
  verifiedAt              DateTime?
  createdAt               DateTime @default(now())


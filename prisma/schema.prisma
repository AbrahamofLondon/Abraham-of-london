//
// ABRAHAM OF LONDON — INSTITUTIONAL DATA MODEL (Production-Grade)
// - PostgreSQL + pgvector enabled for semantic discovery
// - SSOT AccessTier enum (replaces MemberTier + Classification)
// - NO HYPHENS in enum values (Prisma limitation) - mapped to hyphens in app
// - Complete relations with proper back-references
// - Strong enums for integrity (roles, statuses, severities)
// - Explicit indexes for auditability + performance
// - Sensible cascades / set-null behavior for retention + compliance
// - Strategy Intake Registry integrated for Decision Engine ingestion

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ============================================================================
// SSOT ACCESS TIER (REPLACES MemberTier + Classification)
// ============================================================================
// Note: Prisma enum values cannot contain hyphens, so we use underscores
// These map to SSOT AccessTier values via the application layer:
//   inner_circle -> "inner-circle"

enum AccessTier {
  public
  member
  inner_circle // maps to "inner-circle" in application
  client
  legacy
  architect
  owner

  @@map("access_tier")
}

// ============================================================================
// ENUMS (Integrity First)
// ============================================================================

enum MemberRole {
  ADMIN
  PRINCIPAL
  DELEGATE
  MEMBER

  @@map("member_role")
}

enum MemberStatus {
  active
  paused
  disabled

  @@map("member_status")
}

enum ContentType {
  Dossier
  Briefing
  Operational_Framework
  Lexicon
  Landing

  @@map("content_type")
}

enum LinkType {
  PREREQUISITE
  COMPLEMENTARY
  DEPENDENCY

  @@map("link_type")
}

enum AnnotationPriority {
  ROUTINE
  URGENT
  MANDATE

  @@map("annotation_priority")
}

enum InquiryStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CLOSED

  @@map("inquiry_status")
}

enum AuditSeverity {
  info
  warning
  high
  critical

  @@map("audit_severity")
}

enum KeyStatus {
  active
  revoked
  expired

  @@map("key_status")
}

enum SessionStatus {
  active
  revoked
  expired

  @@map("session_status")
}

// ============================================================================
// 1. CORE IDENTITY & MEMBERSHIP
// ============================================================================

model InnerCircleMember {
  id String @id @default(cuid())

  // Identity (privacy-by-design: treat emailHash as the real stable key)
  emailHash String  @unique
  email     String? @unique
  name      String?

  // Role & Status (normalized + enforced)
  role   MemberRole   @default(MEMBER)
  tier   AccessTier   @default(member) // SSOT: replaces MemberTier
  status MemberStatus @default(active)

  // Activity Tracking
  viewCount  Int      @default(0)
  lastSeenAt DateTime @default(now())

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations (with proper back-references)
  annotations     PrivateAnnotation[]
  inquiries       StrategyInquiry[]
  strategyIntakes StrategyIntake[]
  downloadEvents  DownloadAuditEvent[]
  sessions        Session[]
  keys            InnerCircleKey[]
  apiKeys         ApiKey[] // Back-reference for ApiKey
  pageViews       PageView[] // Back-reference for PageView
  preferences     UserPreference? // One-to-one with UserPreference

  @@index([status])
  @@index([tier])
  @@index([role])
  @@index([lastSeenAt])
  @@map("inner_circle_members")
}

// ============================================================================
// 2. INTELLIGENCE & SEMANTIC SEARCH
// ============================================================================

model ContentMetadata {
  id String @id @default(cuid())

  // Stable identifier used across MDX/PDF registry
  slug  String @unique
  title String

  // Typing & classification
  contentType ContentType @default(Briefing)

  // SSOT: classification is an AccessTier (replaces PUBLIC/PRIVATE/RESTRICTED)
  classification AccessTier @default(client)

  // Content core
  summary String? @db.Text
  content String? @db.Text

  // Cryptographic & Structural Metadata
  // Stores { iv: string, authTag: string, isEncrypted: boolean, sha256: string }
  metadata Json?  @default("{}")
  version  String @default("1.0.0")

  // Vector embedding for semantic search (pgvector)
  embedding Unsupported("vector(1536)")?

  // Strategic metrics
  totalPrints     Int   @default(0)
  engagementScore Float @default(0.0)

  // Relations
  annotations     PrivateAnnotation[]
  dependencies    StrategicLink[]     @relation("SourceBrief")
  dependents      StrategicLink[]     @relation("TargetBrief")
  sourceRelations ContentRelation[]   @relation("SourceRelations") // Back-reference for ContentRelation
  targetRelations ContentRelation[]   @relation("TargetRelations") // Back-reference for ContentRelation
  canonEntries    CanonEntry[] // Back-reference for CanonEntry

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([classification])
  @@index([contentType])
  @@map("content_metadata")
}

model StrategicLink {
  id       String @id @default(cuid())
  sourceId String
  targetId String

  strength Float    @default(1.0)
  linkType LinkType @default(DEPENDENCY)

  sourceBrief ContentMetadata @relation("SourceBrief", fields: [sourceId], references: [id], onDelete: Cascade)
  targetBrief ContentMetadata @relation("TargetBrief", fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
  @@index([linkType])
  @@map("strategic_links")
}

// ============================================================================
// 3. PRIVATE ANNOTATIONS (Commander's Intent)
// ============================================================================

model PrivateAnnotation {
  id       String             @id @default(cuid())
  body     String             @db.Text
  priority AnnotationPriority @default(ROUTINE)

  memberId String
  member   InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  contentId String
  content   ContentMetadata @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // Optional embedding for searching personal notes
  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([contentId])
  @@index([priority])
  @@map("private_annotations")
}

// ============================================================================
// 4. STRATEGY INTAKE & INQUIRY REGISTRY
// ============================================================================

model StrategyInquiry {
  id     String @id @default(cuid())
  name   String
  email  String
  intent String @db.Text

  status   InquiryStatus @default(PENDING)
  metadata Json?

  memberId String?
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([memberId])
  @@map("strategy_inquiries")
}

model StrategyIntake {
  id              String @id @default(cuid())
  fullName        String
  organisation    String
  dependencyLevel String
  volatility      String
  readinessScore  Int    @default(5)

  // Stores the full telemetry and reasoning from the Strategy Room form
  payload Json

  memberId String?
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisation])
  @@index([memberId])
  @@index([createdAt])
  @@map("strategy_intakes")
}

// ============================================================================
// 5. INFRASTRUCTURE & AUDIT
// ============================================================================

model SystemConfig {
  id          String  @id @default(cuid())
  key         String  @unique // e.g., "app.version", "security.encryption_mode"
  value       String
  type        String  @default("string") // e.g., "string", "boolean", "number"
  description String?
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("system_configs")
}

model SystemAuditLog {
  id       String        @id @default(cuid())
  action   String // e.g., "BOARD_MEMO_PRINT", "ADMIN_LOGIN_FAILED"
  severity AuditSeverity @default(info)

  actorId    String?
  resourceId String?

  ipAddress String?
  userAgent String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([severity])
  @@index([actorId])
  @@index([resourceId])
  @@index([createdAt])
  @@map("system_audit_logs")
}

// ============================================================================
// 6. SESSIONS, KEYS, DOWNLOAD EVENTS
// ============================================================================

model Session {
  id        String @id @default(cuid())
  sessionId String @unique

  memberId String?
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: Cascade)

  status    SessionStatus @default(active)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([expiresAt])
  @@index([status])
  @@map("sessions")
}

model InnerCircleKey {
  id       String            @id @default(cuid())
  memberId String
  member   InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // store only hashed keys
  keyHash String    @unique
  status  KeyStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@map("inner_circle_keys")
}

model DownloadAuditEvent {
  id String @id @default(cuid())

  slug         String
  printAssetId String? // Link to specific print asset

  memberId String?
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // Optional telemetry fields for investigations / analytics
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // Relations - ONLY ONE relation to PrintAsset
  printAsset PrintAsset? @relation(fields: [printAssetId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([memberId])
  @@index([printAssetId])
  @@index([createdAt])
  @@map("download_audit_events")
}

// ============================================================================
// 7. STRATEGIC FRAMEWORKS (mirroring static data)
// ============================================================================

model StrategicFramework {
  id        String   @id @default(cuid())
  key       String   @unique
  slug      String   @unique
  title     String
  oneLiner  String
  tag       String
  accent    String
  canonRoot String
  audience  String[] // Array of audience types

  // SSOT tier enforcement
  tier AccessTier @default(member)

  // Content
  content     String? @db.Text
  artifactUrl String?

  // Relations
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier])
  @@index([slug])
  @@map("strategic_frameworks")
}

// ============================================================================
// 8. PRINT/PDF ASSETS (for downloads)
// ============================================================================

model PrintAsset {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?

  // SSOT access control
  tier AccessTier @default(member)

  // File metadata
  filePath   String
  fileSize   Int?
  fileFormat String? // PDF, EPUB, etc.

  // Relations - this matches the one in DownloadAuditEvent
  downloads DownloadAuditEvent[] // No @relation needed if naming is consistent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier])
  @@index([slug])
  @@map("print_assets")
}

// ============================================================================
// 9. CANON CONTENT REGISTRY
// ============================================================================

model CanonEntry {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?

  // SSOT access control
  tier AccessTier @default(member)

  // Content metadata
  contentType String // "book", "canon", "essay", etc.
  readTime    Int?

  // Relations
  metadataId String?
  metadata   ContentMetadata? @relation(fields: [metadataId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier])
  @@index([contentType])
  @@map("canon_entries")
}

// ============================================================================
// 10. API KEYS WITH TIER ACCESS
// ============================================================================

model ApiKey {
  id      String @id @default(cuid())
  name    String
  keyHash String @unique

  // SSOT tier for this key
  tier AccessTier @default(member)

  // Rate limiting
  rateLimit Int @default(100) // requests per hour

  // Relations
  memberId String?
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  lastUsedAt DateTime?
  expiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyHash])
  @@index([tier])
  @@index([expiresAt])
  @@map("api_keys")
}

// ============================================================================
// 11. ANALYTICS & METRICS
// ============================================================================

model PageView {
  id   String  @id @default(cuid())
  path String
  slug String?

  // Who viewed (if authenticated)
  memberId String?
  member   InnerCircleMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // What tier was required vs user tier
  requiredTier AccessTier?
  userTier     AccessTier?

  // Context
  referrer  String?
  userAgent String?
  ipAddress String? // Store hashed for privacy

  viewedAt DateTime @default(now())

  @@index([path])
  @@index([memberId])
  @@index([viewedAt])
  @@map("page_views")
}

// ============================================================================
// 12. CONTENT RELATIONSHIPS (beyond just dependencies)
// ============================================================================

model ContentRelation {
  id String @id @default(cuid())

  sourceId String
  targetId String

  relationType String // "series", "sequel", "prequel", "related", "supplements"
  weight       Float  @default(1.0)

  source ContentMetadata @relation("SourceRelations", fields: [sourceId], references: [id], onDelete: Cascade)
  target ContentMetadata @relation("TargetRelations", fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId])
  @@index([targetId])
  @@map("content_relations")
}

// ============================================================================
// 13. USER PREFERENCES & PERSONALIZATION
// ============================================================================

model UserPreference {
  id String @id @default(cuid())

  memberId String            @unique
  member   InnerCircleMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // Preferences
  theme              String? @default("dark")
  emailNotifications Boolean @default(true)
  digestFrequency    String? // "daily", "weekly", "monthly"

  // Bookmarked content
  bookmarks Json? @default("[]")

  // Reading history
  lastReadAt DateTime?

  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ============================================================================
// 14. SYSTEM EVENTS & WEBHOOKS
// ============================================================================

model SystemEvent {
  id        String @id @default(cuid())
  eventType String // "content.published", "user.onboarded", etc.

  // Event data
  payload Json
  source  String? // "system", "webhook", "admin"

  // Processing status
  status      String    @default("pending") // pending, processed, failed
  processedAt DateTime?
  error       String?

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("system_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// DECISION INSTRUMENT RUN
// Authority model for governed instrument execution and delivery.
// Each paid instrument run must persist result, entitlement, artifact state,
// and next-route recommendation. No run should continue if persistence fails.
// ─────────────────────────────────────────────────────────────────────────────

model DecisionInstrumentRun {
  id                  String    @id @default(cuid())
  instrumentSlug      String                                  // e.g. "decision-exposure-instrument"
  userId              String?                                 // null for anonymous (should be blocked by entitlement gate)
  userEmail           String?
  entitlementSlug     String                                  // catalog entitlement slug verified before run
  entitlementVerified Boolean   @default(false)               // true once entitlement check passed
  inputSnapshotHash   String?                                 // SHA-256 of input JSON at run start
  status              String    @default("STARTED")           // STARTED | COMPLETED | FAILED | ABANDONED
  scoreJson           Json?                                   // final scored result
  artifactState       String    @default("NONE")              // NONE | GENERATING | READY | ERROR
  artifactUrl         String?                                 // URL to generated PDF artifact
  artifactHash        String?                                 // SHA-256 of artifact content
  nextRouteSlug       String?                                 // recommended next product route
  runDurationMs       Int?                                    // how long the run took
  errorMessage        String?                                 // set if status=FAILED
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  completedAt         DateTime?

  @@index([instrumentSlug])
  @@index([userId])
  @@index([userEmail])
  @@index([status])
  @@index([entitlementSlug])
  @@index([createdAt])
  @@map("decision_instrument_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// OVERSIGHT REVIEW CYCLE
// Monthly/periodic oversight record for Retainer Oversight product.
// Each cycle persists review state, interventions, drift, and client status.
// Required before Retainer Oversight can move to public_active exposure.
// ─────────────────────────────────────────────────────────────────────────────

model OversightReviewCycle {
  id                  String    @id @default(cuid())
  contractId          String                                  // links to RetainerContract
  cycleNumber         Int                                     // sequential cycle number within contract
  periodStart         DateTime
  periodEnd           DateTime
  status              String    @default("OPEN")              // OPEN | UNDER_REVIEW | COMPLETED | SKIPPED
  reviewedBy          String?                                 // reviewer email/name
  reviewedAt          DateTime?
  driftScore          Float?                                  // governance drift score 0–1
  driftCategory       String?                                 // NONE | LOW | MODERATE | HIGH | CRITICAL
  clientHealthStatus  String    @default("UNKNOWN")           // HEALTHY | WATCH | DETERIORATING | CRITICAL | UNKNOWN
  interventionCount   Int       @default(0)
  interventionLog     Json      @default("[]")                // array of InterventionLogEntry
  outcomeSummary      String?
  clientNotes         String?
  internalNotes       String?
  nextCycleDate       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([contractId, cycleNumber])
  @@index([contractId])
  @@index([status])
  @@index([periodStart])
  @@index([clientHealthStatus])
  @@map("oversight_review_cycles")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTELLIGENCE SPINE
//
// The canonical evidence spine that underpins Boardroom Brief and paid advisory
// products. Replaces the buildSpineFromOrder() placeholder pattern.
// A spine is created from a qualifying diagnostic run, ER run, or bridge run
// and linked to the orders that consumed it.
//
// Rule: no Boardroom Brief may be generated without a resolvable IntelligenceSpine.
// ─────────────────────────────────────────────────────────────────────────────

model IntelligenceSpine {
  id                  String    @id @default(cuid())
  spineId             String    @unique                        // stable external ID (e.g. "SPINE-{cuid}")
  sourceType          String                                   // DIAGNOSTIC_RUN | ER_BOARDROOM_BRIDGE_RUN | EXECUTIVE_REPORT | MANUAL
  diagnosticId        String?                                  // FK to originating diagnostic (if sourceType=DIAGNOSTIC_RUN)
  erRunId             String?                                  // FK to ER run (if sourceType=ER_BOARDROOM_BRIDGE_RUN)
  executiveReportId   String?                                  // FK to executive report
  organisationId      String?                                  // FK to Organisation if enterprise-sourced
  userId              String?                                  // user who created/owns this spine
  userEmail           String?
  decisionSubject     String                                   // what decision/situation this spine covers
  decisionContext     Json?                                    // structured context object
  evidenceNodes       Json      @default("[]")                 // array of EvidenceNode records
  authorityLevel      String    @default("CANDIDATE")          // CANDIDATE | QUALIFYING | VERIFIED | RETIRED
  isSample            Boolean   @default(false)                // true = cannot be used for paid production delivery
  qualifyingChecks    Json?                                    // record of which authority checks passed
  inputSnapshotHash   String?                                  // SHA-256 of evidence nodes at qualifying time
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  retiredAt           DateTime?

  // Boardroom briefs generated from this spine
  boardroomOrders     BoardroomBriefOrder[]  @relation("SpineOrders")

  @@index([spineId])
  @@index([sourceType])
  @@index([userId])
  @@index([userEmail])
  @@index([organisationId])
  @@index([authorityLevel])
  @@index([isSample])
  @@index([createdAt])
  @@map("intelligence_spines")
}

// ─────────────────────────────────────────────────────────────────────────────
// DECISION OUTCOME RECORD (Return Brief 2.0)
//
// Captures what happened after a decision was made. Linked to the originating
// case/run/order. Submitted via Return Brief request when decision deadline passes.
// ─────────────────────────────────────────────────────────────────────────────

model DecisionOutcomeRecord {
  id                  String    @id @default(cuid())
  // Source linkage — at least one must be populated
  decisionInstrumentRunId  String?                            // FK to DecisionInstrumentRun
  boardroomDossierId       String?                            // FK to BoardroomDossier
  decisionObjectId         String?                            // FK to DiagnosticDecisionObject
  strategySessionId        String?                            // FK to StrategySession (if applicable)
  // Identity
  submittedByEmail    String?
  submittedByUserId   String?
  // Outcome classification
  outcomeClass        String                                  // SUCCESS | MITIGATED | PARTIAL | FAILURE | DEFERRED | UNKNOWN
  outcomeDetail       String?                                 // free-text: what happened
  ownerCorrect        Boolean?                                // was the original owner/decision-maker correct?
  evidenceMissing     Boolean   @default(false)               // was critical evidence missing at decision time?
  evidenceMissingNote String?
  whatChanged         String?                                 // what changed after the decision was made
  carryForward        String?                                 // what should be carried into the next cycle
  // Timing
  decisionDeadline    DateTime?                               // the deadline that triggered this Return Brief
  outcomeDate         DateTime?                               // when the outcome was observed
  // Memory feedback
  memorySummary       String?                                 // AI-generated memory note for future similar decisions
  // Audit
  reviewedByAdmin     Boolean   @default(false)
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([decisionInstrumentRunId])
  @@index([boardroomDossierId])
  @@index([decisionObjectId])
  @@index([outcomeClass])
  @@index([submittedByEmail])
  @@index([createdAt])
  @@map("decision_outcome_records")
}

model ReturnBriefRequest {
  id                  String    @id @default(cuid())
  requestKey          String    @unique
  outcomeHypothesisId String?
  productCode         String
  sourceEntityType    String
  sourceEntityId      String
  userEmail           String?
  userId              String?
  dueAt               DateTime
  status              String    @default("PENDING") // PENDING | SENT | SUBMITTED | EXPIRED | CANCELLED
  sentAt              DateTime?
  submittedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  responses           ReturnBriefResponse[]

  @@index([outcomeHypothesisId])
  @@index([productCode])
  @@index([sourceEntityType, sourceEntityId])
  @@index([userEmail])
  @@index([status])
  @@index([dueAt])
  @@map("return_brief_requests")
}

model ReturnBriefResponse {
  id                      String   @id @default(cuid())
  requestId               String?
  decisionOutcomeRecordId String?
  submittedByEmail        String?
  outcomeClass            String
  responsePayload         Json     @default("{}")
  evidenceRefs            Json     @default("[]")
  createdAt               DateTime @default(now())

  request                 ReturnBriefRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([decisionOutcomeRecordId])
  @@index([submittedByEmail])
  @@index([outcomeClass])
  @@index([createdAt])
  @@map("return_brief_responses")
}

model OutcomePatternObservation {
  id                      String   @id @default(cuid())
  decisionOutcomeRecordId String?
  userEmail               String?
  patternObservationId    String?
  patternType             String
  riskOfRepeat            String?
  observationSummary      String

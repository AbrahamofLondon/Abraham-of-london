  latestVersion String?
  generatedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportOrders  DiagnosticReportOrder[]
  artifacts     DiagnosticArtifact[]
  accessGrants  DiagnosticArtifactAccessGrant[]
  lineageEvents DiagnosticLineageEvent[]
  auditEvents   DiagnosticAuditEvent[]
  regenJobs     DiagnosticRegenerationJob[]

  @@index([userEmail, createdAt])
  @@index([userId, createdAt])
  @@index([diagnosticType, createdAt])
  @@index([reportStatus, createdAt])

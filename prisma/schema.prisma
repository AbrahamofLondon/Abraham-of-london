model DecisionSignalRegistry {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  registryKey     String   @unique // Unique identifier for the specific observation trace

  // POLYMORPHIC LINKING
  // This allows the registry to track Campaign Assets, Participants, or even API routes
  assetId         String
  assetTitle      String
  assetHref       String?
  assetKind       String

  contextType     String   // e.g., "PARTICIPANT_AUDIT"
  contextValue    String   // e.g., the participantId

  status          String   @default("ACTIVE")
  highestSeverity String   @default("info") // info, warning, critical

  healthScore     Float    @default(0)
  driftScore      Float    @default(0)
  resonanceScore  Float    @default(0)
  confidenceScore Float?
  resonanceBand   String?

  alertCount      Int      @default(0)
  lastEvaluatedAt DateTime?

  // RELATION TO METRIC DEFINITION
  metricKey       String?
  metric          GovernanceMetricDefinition? @relation(fields: [metricKey], references: [key], onDelete: SetNull)

  // RELATION TO EFFICACY (Existing)
  assetEfficacyId String?
  assetEfficacy   DecisionAssetEfficacy? @relation(fields: [assetEfficacyId], references: [id], onDelete: SetNull)

  // RELATION TO CONTEXT PERFORMANCE (Existing)
  contextPerformanceId String?
  contextPerformance   DecisionAssetContextPerformance? @relation(fields: [contextPerformanceId], references: [id], onDelete: SetNull)

  metrics         Json?
  alerts          Json?
  metadata        Json?

  governanceAlerts DecisionGovernanceAlert[]

  @@unique([assetId, contextType, contextValue])
  @@index([assetId])
  @@index([status])
  @@index([highestSeverity])
  @@map("decision_signal_registry")
}


{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm contentlayer2 build && node scripts/pre-build.mjs && tsx scripts/build-pdf-registry-json.ts && cross-env NODE_OPTIONS='--max-old-space-size=6144' next build --webpack && node scripts/clean-standalone.mjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1",
    "NEXT_SKIP_TYPE_CHECK": "1"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

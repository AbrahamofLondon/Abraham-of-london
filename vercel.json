{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm contentlayer2 build && node scripts/pre-build.mjs && tsx scripts/build-pdf-registry-json.ts && tsx scripts/generate-library-index-lite.ts && cross-env NODE_OPTIONS='--max-old-space-size=3072' next build --webpack && node scripts/clean-standalone.mjs",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1",
    "NEXT_SKIP_TYPE_CHECK": "1"
  },
  "crons": [
    { "path": "/api/cron/decision-state", "schedule": "0 * * * *" },
    { "path": "/api/cron/escalation",     "schedule": "0 */6 * * *" },
    { "path": "/api/cron/calibration",    "schedule": "0 3 * * *" },
    { "path": "/api/cron/snapshot",       "schedule": "0 2 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
